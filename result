package com.aramco.easd.dailyoperations.resource;

import com.aramco.easd.dailyoperations.dto.ApiResponse;
import com.aramco.easd.dailyoperations.service.DailyOperationService;
import com.fasterxml.jackson.databind.JsonNode;
import jakarta.inject.Inject;
import jakarta.ws.rs.*;
import jakarta.ws.rs.core.MediaType;
import org.jboss.logging.Logger;
import java.util.List;

@Path("/daily-operation/api/v1")
@Produces(MediaType.APPLICATION_JSON)
@Consumes(MediaType.APPLICATION_JSON)
public class DailyOperationResource {

    private static final Logger LOG = Logger.getLogger(DailyOperationResource.class);

    @Inject
    DailyOperationService service;

    /**
     * GET /wwells?date=2024-05-08
     * Returns the list of well identifiers (epANum, wellName) from wwell-name-and-epANum copy.json
     */
    @GET
    @Path("/wwells")
    public ApiResponse<List<JsonNode>> getWellIdentifiers(@QueryParam("date") String date) {
        if (date == null || date.isBlank()) {
            return ApiResponse.error(400, "Missing required query parameter: date (format yyyy-MM-dd)");
        }
        if (!date.matches("\\d{4}-\\d{2}-\\d{2}")) {
            return ApiResponse.error(400, "Invalid date format. Expected yyyy-MM-dd");
        }

        LOG.infof("Fetching well identifiers for date: %s (date ignored, returning full list)", date);
        List<JsonNode> identifiers = service.getAllWellIdentifiers();
        return ApiResponse.success(identifiers);
    }

    /**
     * GET /wwells?date=2024-05-08&epANum=98415
     * Returns the complete well data (from drlg-mr copy.json) if the epANum and date match.
     */
    @GET
    @Path("/wwells")
    public ApiResponse<List<JsonNode>> getFullWellData(@QueryParam("date") String date,
                                                       @QueryParam("epANum") Long epANum) {
        if (date == null || date.isBlank()) {
            return ApiResponse.error(400, "Missing required query parameter: date");
        }
        if (epANum == null) {
            return ApiResponse.error(400, "Missing required query parameter: epANum");
        }
        if (!date.matches("\\d{4}-\\d{2}-\\d{2}")) {
            return ApiResponse.error(400, "Invalid date format. Expected yyyy-MM-dd");
        }

        LOG.infof("Fetching full well data for date: %s, epANum: %d", date, epANum);
        JsonNode well = service.getFullWellDataIfMatches(epANum, date);
        if (well == null) {
            return ApiResponse.error(404, "No well found matching the given date and epANum");
        }
        return ApiResponse.success(List.of(well));   // wrap in list because return type is List<JsonNode>
    }
}
