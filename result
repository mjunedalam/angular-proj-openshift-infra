package com.aramco.easd.dailyoperations.service;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import jakarta.annotation.PostConstruct;
import jakarta.enterprise.context.ApplicationScoped;
import java.io.InputStream;
import java.util.ArrayList;
import java.util.List;
import java.util.stream.StreamSupport;

@ApplicationScoped
public class DailyOperationService {

    private ObjectMapper mapper;
    private List<JsonNode> wellIdentifiers;   // from wwell-name-and-epANum copy.json
    private JsonNode fullWellData;            // the single well object from drlg-mr copy.json

    @PostConstruct
    public void init() {
        mapper = new ObjectMapper();
        loadWellIdentifiers();
        loadFullWellData();
    }

    private void loadWellIdentifiers() {
        try (InputStream is = getClass().getResourceAsStream("/wwell-name-and-epANum copy.json")) {
            JsonNode array = mapper.readTree(is);
            wellIdentifiers = new ArrayList<>();
            array.forEach(wellIdentifiers::add);
        } catch (Exception e) {
            throw new RuntimeException("Failed to load well identifiers JSON", e);
        }
    }

    private void loadFullWellData() {
        try (InputStream is = getClass().getResourceAsStream("/drlg-mr copy.json")) {
            JsonNode array = mapper.readTree(is);
            if (array.isArray() && array.size() > 0) {
                fullWellData = array.get(0);   // only one well in the file
            } else {
                throw new RuntimeException("drlg-mr copy.json does not contain a well object");
            }
        } catch (Exception e) {
            throw new RuntimeException("Failed to load full well data JSON", e);
        }
    }

    /**
     * Returns the complete list of well identifiers (epANum + wellName).
     */
    public List<JsonNode> getAllWellIdentifiers() {
        return wellIdentifiers;
    }

    /**
     * Returns the full well data if the requested epANum and date match the well's DRLG_OP_STATUS.
     * Since only one well exists, we simply compare.
     */
    public JsonNode getFullWellDataIfMatches(long epANum, String date) {
        JsonNode opStatus = fullWellData.get("DRLG_OP_STATUS");
        if (opStatus != null && opStatus.isArray() && opStatus.size() > 0) {
            long actualEpANum = opStatus.get(0).get("epANum").asLong();
            String actualDate = opStatus.get(0).get("wActDt").asText();
            if (actualEpANum == epANum && actualDate.startsWith(date)) {
                return fullWellData;
            }
        }
        return null;
    }
}
