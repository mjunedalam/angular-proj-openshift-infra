@Path("/daily-operation/api/v1")
@Produces(MediaType.APPLICATION_JSON)
public class DailyOperationResource {

    @Inject DummyDailyOperationService service;

    @GET
    @Path("/wwells")
    public ApiResponse<List<JsonNode>> getWwells(@QueryParam("date") String date) {
        if (date == null || date.isBlank()) {
            return ApiResponse.error(400, "Missing date");
        }
        List<JsonNode> wells = service.getWellsByDate(date);
        if (wells.isEmpty()) {
            return ApiResponse.error(404, "No wells found");
        }
        return ApiResponse.success(wells);
    }

    @GET
    @Path("/wwells")
    public ApiResponse<List<JsonNode>> getWwellsByDateAndEpANum(
            @QueryParam("date") String date,
            @QueryParam("epANum") Long epANum) {
        if (date == null || epANum == null) {
            return ApiResponse.error(400, "Missing date or epANum");
        }
        JsonNode well = service.getWellByEpANumAndDate(epANum, date);
        if (well == null) {
            return ApiResponse.error(404, "Well not found");
        }
        return ApiResponse.success(List.of(well));
    }
}
