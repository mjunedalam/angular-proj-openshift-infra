import { computed, inject } from '@angular/core';
import { HttpClient } from '@angular/common/http';
import { Router } from '@angular/router';
import { patchState, signalStore, withComputed, withMethods, withState } from '@ngrx/signals';
import { firstValueFrom } from 'rxjs';
import { JwtService } from '../../service/jwt.service';
import { LoaderService } from 'src/app/shared/components/global-loader/loader.service';
import { ExternalConfigService } from 'src/services/external-config.service';
import {
  AuthUser,
  AuthState,
  initialState,
  LoginRequest,
  selectDisplayUsername,
  selectIsTokenExpired, 
  selectUserEmail,
} from './auth.selectors';

export const AuthStore = signalStore(
  { providedIn: 'root' },
  withState<AuthState>(initialState),
  withComputed(({ token, user }) => ({
    isTokenExpired: computed(() => selectIsTokenExpired(token(), inject(JwtService))),
    displayUsername: computed(() => selectDisplayUsername(user())),
    userEmail: computed(() => selectUserEmail(user())),
  })),
  withMethods((
    store,
    http = inject(HttpClient),
    router = inject(Router),
    jwt = inject(JwtService),
    loading = inject(LoaderService),
    extAppConfigService = inject(ExternalConfigService),
  ) => ({
    async login(_credentials?: LoginRequest): Promise<void> {
      patchState(store, { isLoading: true, error: null });
      loading.show();

      try {
        const token = await firstValueFrom(
          http.get(extAppConfigService.settings.tokenUrl, {
            responseType: 'text',
            withCredentials: true,
          }),
        );

        if (!token?.trim()) {
          throw new Error('Authentication token was empty.');
        }

        if (jwt.isExpired(token)) {
          throw new Error('Authentication token is expired.');
        }

        const user = jwt.decode<AuthUser>(token);

        patchState(store, {
          token,
          isAuthenticated: true,
          user,
          isLoading: false,
          error: null,
        });

        await router.navigate(['/home']);
      } catch (error) {
        patchState(store, {
          ...initialState,
          error: error instanceof Error ? error.message : 'Login failed.',
        });
      } finally {
        loading.hide();
      }
    },

    logout() {
      patchState(store, initialState);
      void router.navigate(['/login']);
    },

    autoLogin() {
      patchState(store, initialState);
    },
  })),
);

