@ApplicationScoped
public class DummyDailyOperationService {

    private ObjectMapper mapper;
    private List<JsonNode> allWells;   // from wwell-name-and-epANum.json

    @PostConstruct
    public void init() {
        mapper = new ObjectMapper();
        loadAllWellsFromFile();
    }

    private void loadAllWellsFromFile() {
        try (InputStream is = getClass().getResourceAsStream("/wwell-name-and-epANum.json")) {
            JsonNode root = mapper.readTree(is);
            allWells = new ArrayList<>();
            for (JsonNode entry : root.get("data")) {
                allWells.add(entry);   // each entry is { "epANum": ..., "wellName": ... }
            }
        } catch (Exception e) {
            throw new RuntimeException("Failed to load wwell-name-and-epANum.json", e);
        }
    }

    // If you really need the full drlg-mr.json structure (nested), load that separately
    public JsonNode getFullDrlgMrData() {
        try (InputStream is = getClass().getResourceAsStream("/drlg-mr.json")) {
            return mapper.readTree(is);
        } catch (Exception e) {
            throw new RuntimeException(e);
        }
    }

    public List<JsonNode> getWellsByDate(String date) {
        // For demo, just return the list from the second JSON (no real date filter)
        // In real life, you'd filter based on date inside each well's DRLG_OP_STATUS.
        // But if you only need to return the raw JSON as-is, ignore date.
        return allWells;
    }

    public JsonNode getWellByEpANumAndDate(long epANum, String date) {
        // Return the entry from wwell-name-and-epANum.json that matches epANum
        return allWells.stream()
                .filter(w -> w.get("epANum").asLong() == epANum)
                .findFirst()
                .orElse(null);
    }
}
