// ── Container ──────────────────────────────────────────────────────────────────
.docs-container {
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

// ── Header (toggle button) ─────────────────────────────────────────────────────
.docs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  width: 100%;
  text-align: left;
  background: transparent;
  border: none;
  cursor: pointer;
  color: inherit;
  transition: background 150ms ease;

  &:hover { background: var(--accent-muted); }

  &__title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 17px;
    font-weight: 800;
    color: var(--text-primary);

    .icon-box {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent-muted);
      border-radius: 8px;
      color: var(--accent);
      flex-shrink: 0;

      svg { width: 16px; height: 16px; }
    }
  }

  &__right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  &__badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px 3px 7px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    line-height: 1.5;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.18), rgba(134, 239, 172, 0.08));
