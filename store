.well-chips-shell {
  display: flex;
  flex-direction: column;
}

// ── Well chips container with date picker ────────────────────────────────────
.well-chips-container {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  gap: 24px;
  padding: 14px 24px;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f9ff 100%);
  backdrop-filter: var(--glass-blur);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  margin: 1.5em 0 1em;
  box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
}

// ── Date picker section — left side ──────────────────────────────────────────
.date-picker-section {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  justify-self: start;
  min-width: 0;
}

.date-picker-label {
  font-size: 13px;
  font-weight: 800;
  color: var(--text-primary);
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.date-picker-input {
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-inner);
  background: #ffffff;
  color: var(--text-primary);
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  min-width: 140px;
  width: auto;
  box-sizing: border-box;
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;
  pointer-events: auto;

  &:hover {
    border-color: var(--accent-hover);
    background: var(--accent-muted);
    box-shadow: var(--shadow-sm);
  }

  &:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--accent-muted);
    box-shadow: 0 0 0 3px var(--accent-muted);
  }

  // Styling the calendar picker icon
  &::-webkit-calendar-picker-indicator {
    cursor: pointer;
    opacity: 1;
    pointer-events: auto;
    width: 24px;
    height: 24px;
    filter: brightness(0.6);
    opacity: 0.9;
  }

  &::-webkit-outer-spin-button,
  &::-webkit-inner-spin-button {
    display: none;
    -webkit-appearance: none;
    margin: 0;
  }

  // Styling for Firefox
  &::-moz-calendar-picker-indicator {
    cursor: pointer;
    opacity: 1;
  }
}

// ── Chip strip — centered relative to the toolbar/card ───────────────────────
.chip-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
  grid-column: 2;
  justify-self: center;
  min-width: 0;
  max-width: min(100%, 900px);
  background: transparent;
  backdrop-filter: none;
  border: none;
  border-radius: 0;
  margin: 0;
  box-shadow: none;
  padding: 0;

  &__label {
    font-size: 13px; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-primary); margin-right: 12px; flex-shrink: 0;
  }
  &__page-indicator {
    font-size: 13px; font-weight: 700;
    color: var(--text-secondary); opacity: 1;
    margin-left: 8px; flex-shrink: 0;
  }
}

@media (max-width: 1100px) {
  .well-chips-container {
    grid-template-columns: 1fr;
    justify-items: center;
  }

  .date-picker-section,
  .chip-strip {
    grid-column: auto;
    justify-self: center;
  }
}

// ── Chip button styles ───────────────────────────────────────────────────────
.chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: var(--radius-inner);
  border: 1px solid var(--border);
  background: #ffffff;
  color: var(--text-primary);
  font-family: inherit;
  font-size: 14px; font-weight: 700;
  cursor: pointer;
  transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
  appearance: none;
  -webkit-appearance: none;
  outline: none;
  -webkit-tap-highlight-color: transparent;
  isolation: isolate;

  &::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 0;
  }

  &:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    background: rgba(14, 165, 233, 0.1);
    box-shadow: var(--shadow-sm);
    &::before { opacity: 1; }
  }

  &--active {
    background: linear-gradient(180deg, #f0fdf4 0%, #dcfce7 100%);
    border-color: #22c55e;
    color: var(--text-primary);
    font-weight: 800;
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.14), 0 10px 20px rgba(34, 197, 94, 0.12);

    .chip__dot {
      background: #16a34a;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.28);
    }

    .chip__text {
      color: var(--text-primary);
    }
  }

  &--nav {
    min-width: 32px; padding: 8px 12px;
    font-size: 18px; color: var(--accent); font-weight: 800;
  }

  &.chip--nav:hover,
  &.chip--nav:focus {
    background: #ffffff;
    color: var(--accent);
    border-color: var(--border);
    box-shadow: none;

    &::before { opacity: 0; }
  }

  &:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.16);
  }

  &__dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(14, 165, 233, 0.35); flex-shrink: 0;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    z-index: 1;
  }

  &__text {
    position: relative;
    z-index: 1;
    color: inherit;
    line-height: 1.3;
  }
}

.well-loading-slot {
  height: 4px;
  margin-top: 6px;
  opacity: 0;
  transition: opacity 0.22s ease;
  pointer-events: none;

  &--active {
    opacity: 1;
  }
}

.well-loading-bar {
  height: 4px;
  --mdc-linear-progress-track-height: 4px;
  --mdc-linear-progress-active-indicator-height: 4px;
  --mdc-linear-progress-track-color: rgba(14, 165, 233, 0.14);
  --mdc-linear-progress-active-indicator-color: transparent;
}

:host ::ng-deep .well-loading-bar .mdc-linear-progress__bar-inner {
  border-top: none !important;
  height: 4px;
  background: linear-gradient(to right, #3b82f6, #22c55e);
}
