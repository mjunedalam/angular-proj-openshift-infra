<?xml version="1.0" encoding="UTF-8" ?>
        <!DOCTYPE mapper
                PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
                "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aramco.easd.dailyoperations.mappers.DailyOperationsMapper">

    <!--
        ResultMap: maps Oracle cursor columns to Well POJO.

        Column names returned by the SELECT inside mr_wells:
            EP_A_NUM   → epANum
            RAC_NUM    → racNum
            W_GNR_NAME → wGnrName
    -->
    <resultMap id="wwellEntryResultMap" type="com.aramco.easd.dailyoperations.models.WwellEntry">
        <result property="epANum"   column="EP_A_NUM"   />
        <result property="racNum"   column="RAC_NUM"    />
        <result property="wGnrName" column="W_GNR_NAME" />
    </resultMap>

    <!--
        Stored-procedure call.

        - statementType="CALLABLE"  → JDBC CallableStatement
        - resultSets (optional)     → not needed; cursor is an OUT param
        - #{resultCrs}              → OUT SYS_REFCURSOR, consumed by resultMap
        - #{pDt}                    → IN  DATE parameter
    -->
    <select id="fetchWwellEntries"
            statementType="CALLABLE"
            parameterType="map">
        {
            call mr_wells(
                #{resultCrs,
                  mode=OUT,
                  jdbcType=CURSOR,
                  javaType=java.sql.ResultSet,
                  resultMap=wwellEntryResultMapp},
                #{pDt,
                  mode=IN,
                  jdbcType=DATE}
                 )
            }
    </select>

</mapper>
