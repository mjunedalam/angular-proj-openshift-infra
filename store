// ── Upload footer ─────────────────────────────────────────────────────────────
.upload-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.1rem;
}

.upload-count {
  font-size: 0.65rem;
  color: #94a3b8;
  font-weight: 500;
}

.upload-submit-btn {
  display: inline-flex !important;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.72rem !important;
  font-weight: 600 !important;
  height: 1.875rem !important;
  padding: 0 0.75rem !important;
  border-radius: 8px !important;
  letter-spacing: 0.02em !important;

  mat-icon {
    font-size: 0.85rem;
    width: 0.85rem;
    height: 0.85rem;
    line-height: 0.85rem;
    overflow: visible;
  }
}

.upload-spinner { display: inline-flex; }

// ── Empty state ───────────────────────────────────────────────────────────────
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 0 0.25rem;
  color: #94a3b8;
  font-size: 0.68rem;
  font-weight: 500;

  &__icon {
    font-size: 1.4rem;
    width: 1.4rem;
    height: 1.4rem;
    line-height: 1.4rem;
    overflow: visible;
    opacity: 0.5;
  }
}
