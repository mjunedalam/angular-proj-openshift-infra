  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding: 0.75rem 1rem;
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  border-radius: 1rem;
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 80%, #0f766e 20%), color-mix(in srgb, var(--accent) 65%, #0f4c81 35%));
  color: #fff;
}

.wwell-map-stat__value {
  font-size: 1.5rem;
  font-weight: 700;
  line-height: 1;
}

.wwell-map-stat__label {
  font-size: 0.8rem;
  opacity: 0.85;
  text-transform: uppercase;
}

.wwell-map-message {
  display: block;
  margin-bottom: 1rem;
  padding: 0.8rem 1rem;
  border-radius: 1rem;
  border: 1px solid color-mix(in srgb, var(--danger) 28%, transparent);
  background: color-mix(in srgb, var(--danger) 10%, white);
  color: var(--danger);
}

.wwell-map-frame {
  position: relative;
  min-height: 90vh;
  overflow: hidden;
  border-radius: 1rem;
  border: 1px solid color-mix(in srgb, var(--map-border) 80%, transparent);
  background: linear-gradient(180deg, color-mix(in srgb, var(--map-panel) 88%, white 12%), var(--map-panel));
