  padding: 0.42rem 0.7rem;
  border-radius: 999px;
  color: #fff;
  font-size: 0.8rem;
  font-weight: 700;
  text-align: center;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.wwell-map-legend__chip--owner {
  background: #cedf5f;
  color: #35530a;
