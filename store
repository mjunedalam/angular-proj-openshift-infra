package com.example.wells.service;

import com.example.wells.dto.ApiResponse;
import com.example.wells.mapper.WellMapper;
import com.example.wells.model.Well;
import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.jboss.logging.Logger;

import java.time.LocalDate;
import java.time.ZoneId;
import java.time.format.DateTimeParseException;
import java.util.Date;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

@ApplicationScoped
public class WellService {

    private static final Logger LOG = Logger.getLogger(WellService.class);

    @Inject
    WellMapper wellMapper;

    @SuppressWarnings("unchecked")
    public ApiResponse<List<Well>> getWells(String dateParam) {

        // ── validation ────────────────────────────────────────────────────────
        if (dateParam == null || dateParam.isBlank()) {
            return ApiResponse.error(400, "Query parameter 'date' is required (format: yyyy-MM-dd)");
        }

        LocalDate date;
        try {
            date = LocalDate.parse(dateParam);
        } catch (DateTimeParseException e) {
            return ApiResponse.error(400, "Invalid date format '" + dateParam + "'. Use yyyy-MM-dd");
        }

        // ── stored procedure call ─────────────────────────────────────────────
        try {
            Date oracleDate = Date.from(
                    date.atStartOfDay(ZoneId.systemDefault()).toInstant());

            Map<String, Object> params = new HashMap<>();
            params.put("pDt", oracleDate);

            wellMapper.callMrWells(params);

            List<Well> results = (List<Well>) params.get("resultCrs");
            LOG.debugf("mr_wells returned %d row(s) for date %s",
                    results == null ? 0 : results.size(), date);

            return ApiResponse.success(results == null ? List.of() : results);

        } catch (Exception e) {
            LOG.errorf(e, "Database error while calling mr_wells for date %s", date);
            return ApiResponse.error(500, "Database error: " + e.getMessage());
        }
    }
}

