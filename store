:host {
  --report-bg: var(--bg-surface);
  --report-border: var(--border);
  --report-border-strong: rgba(148, 163, 184, 0.26);
  --report-shadow: 0 18px 48px rgba(15, 23, 42, 0.12);
  --report-text: var(--text-primary);
  --report-muted: var(--text-secondary);
  --report-panel: color-mix(in srgb, var(--bg-card) 88%, white 12%);
  --report-header-start: #4ec4f0;
  --report-header-end: #3b82f6;
  --report-green-start: #37b700;
  --report-green-end: #178b00;
  --report-blue-start: #2fb0e2;
  --report-blue-end: #147ec5;
  --report-summary-start: #2241bf;
  --report-summary-end: #0f73ff;
  --report-value-bg: color-mix(in srgb, var(--bg-surface) 92%, white 8%);
  --wasi-color: #3b82f6;
  --ownership-color: #10b981;
  --aquifer-color: #f59e0b;
  --active-well-color: #ef4444;

  display: block;
  padding: 2rem 1rem 3rem;
  background: var(--bg-app);
}

.report-shell {
  max-width: 1080px;
  margin: 0 auto;
  padding: 1rem 1rem 2rem;
  border: 1px solid var(--report-border);
  border-radius: 24px;
  background: var(--report-bg);
  box-shadow: var(--report-shadow);
  color: var(--report-text);
}

.report-header {
  margin-bottom: 1.25rem;
}

.report-header__bar {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 3.4rem;
  border: 1px solid color-mix(in srgb, var(--report-header-end) 28%, white 20%);
  border-radius: 16px;
  background: linear-gradient(180deg, var(--report-header-start), var(--report-header-end));
}

.report-header__title {
  color: #fff;
  font-size: 1.2rem;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.report-toolbar {
  display: flex;
  align-items: center;
  gap: 1rem;
  justify-content: space-between;
  margin-bottom: 1.25rem;
}

.date-picker-section {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.date-picker-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.date-picker-input {
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-inner);
  background: var(--bg-card);
  color: var(--text-primary);
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease;
  min-width: 140px;
  appearance: none;

  &:hover {
    border-color: var(--accent-hover);
    background: var(--accent-muted);
    box-shadow: var(--shadow-sm);
  }

  &:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--accent-muted);
    box-shadow: 0 0 0 3px var(--accent-muted);
  }

  &::-webkit-calendar-picker-indicator {
    cursor: pointer;
    opacity: 0.9;
    width: 24px;
    height: 24px;
    filter: brightness(0.6);
  }
}

.report-loading-bar {
  position: fixed;
  top: 62px;
  left: 0;
  right: 0;
  height: 3px;
  z-index: 99;
  --mdc-linear-progress-track-height: 3px;
  --mdc-linear-progress-active-indicator-height: 3px;
  --mdc-linear-progress-track-color: transparent;
  --mdc-linear-progress-active-indicator-color: transparent;
}

:host ::ng-deep .report-loading-bar .mdc-linear-progress__bar-inner {
  border-top: none !important;
  height: 4px;
  background: linear-gradient(to right, #3b82f6, #22c55e);
}

.email-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  padding: 0.55rem 1.1rem 0.55rem 0.85rem;
  border: 1px solid rgba(148, 163, 184, 0.5);
  border-radius: 10px;
  background: var(--bg-card);
  color: var(--text-primary);
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.18);
  transition: background 180ms ease, border-color 180ms ease, color 180ms ease;

  &:hover {
    background: var(--bg-surface);
    border-color: var(--accent);
    color: var(--accent);

    .email-btn__arrow { transform: translateX(3px); }
  }

  &:active { transform: scale(0.97); }
}

.email-btn__icon,
.email-btn__arrow {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.email-btn__icon svg { width: 15px; height: 15px; }

.email-btn__label { white-space: nowrap; }

.email-btn__arrow {
  opacity: 0.7;
  transition: transform 180ms ease;
  svg { width: 13px; height: 13px; }
}

.report-content {
  display: flex;
  flex-direction: column;
  gap: 1.15rem;
  transition: opacity 200ms ease;

  &--loading {
    opacity: 0.4;
    pointer-events: none;
  }
}

.report-error {
  padding: 0.95rem 1.1rem;
  border: 1px solid color-mix(in srgb, var(--danger) 38%, transparent);
  border-radius: 16px;
  background: color-mix(in srgb, var(--danger) 10%, var(--report-bg));
  color: var(--danger);
}

.report-empty {
  padding: 1.1rem 1.2rem;
  border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
  border-radius: 16px;
  background: color-mix(in srgb, var(--accent-muted) 72%, var(--report-bg));
  color: var(--report-text);
  text-align: center;
  font-size: 0.98rem;
  font-weight: 600;
}

.report-section {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.report-section__heading {
  display: flex;
  justify-content: center;
  padding: 0.3rem 0 0.1rem;
}

.report-section__title {
  color: var(--report-muted);
  font-size: 1.25rem;
  font-weight: 700;
  text-align: center;
}

.report-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border: 1px solid var(--report-border-strong);
  border-radius: 14px;
  overflow: hidden;
}

.report-card {
  overflow: hidden;
  border: 1px solid var(--report-border-strong);
  border-radius: 0;
  background: var(--bg-card);
  margin-right: -1px;
  margin-bottom: -1px;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding: 0.65rem 0.85rem;

  &--blue {
    background: linear-gradient(90deg, var(--report-summary-start), var(--report-summary-end));
  }

  &--green {
    background: linear-gradient(90deg, var(--report-green-start), var(--report-green-end));
  }
}

.card-header__left {
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}

.card-header__name {
  color: #fff;
  font-size: 1.25rem;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-header__rig {
  color: rgba(255, 255, 255, 0.78);
  font-size: 0.95rem;
  font-weight: 600;
}

.card-header__badge {
  color: rgba(255, 255, 255, 0.88);
  font-size: 0.82rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.14);
  flex-shrink: 0;
}

.card-header__status-input {
  width: 150px;
  flex-shrink: 0;
  padding: 5px 12px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.13);
  color: #fff;
  font-family: inherit;
  font-size: 0.88rem;
  font-weight: 600;
  text-align: center;

  &::placeholder { color: rgba(255, 255, 255, 0.7); }
  &:focus { outline: none; background: rgba(255, 255, 255, 0.22); }

  &--na {
    border-color: rgba(239, 68, 68, 0.7);
    background: rgba(239, 68, 68, 0.22);
    color: #fca5a5;

    &::placeholder { color: rgba(252, 165, 165, 0.7); }
    &:focus { background: rgba(239, 68, 68, 0.32); }
  }
}

.card-table {
  width: 100%;
  border-collapse: collapse;

  tbody tr {
    border-bottom: 1px solid var(--report-border);

    &:last-child { border-bottom: none; }

    &:hover .card-table__value {
      background: color-mix(in srgb, var(--bg-card) 92%, var(--accent) 8%);
    }
  }
}

.card-table__label {
  width: 22%;
  padding: 0.75rem 1rem;
  background: linear-gradient(90deg, var(--report-blue-start), var(--report-blue-end));
  color: #fff;
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: 0.01em;
  border-right: 2px solid rgba(255, 255, 255, 0.18);
  vertical-align: middle;
  white-space: nowrap;

  .report-card--test & {
    background: linear-gradient(90deg, var(--report-green-start), var(--report-green-end));
  }
}

.card-table__value {
  padding: 0.75rem 1rem;
  background: var(--bg-card);
  color: var(--report-text);
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  vertical-align: middle;
  transition: background 180ms ease;

  &.missing {
    color: var(--danger);
    font-style: italic;
    opacity: 0.85;
  }
  &.present { color: var(--accent); }

  &--op {
    text-align: left;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.55;
    color: var(--text-primary);
  }
}

.report-map-section {
  margin-top: 0.5rem;
  border: 1px solid var(--report-border-strong);
  border-radius: 16px;
  background: var(--report-panel);
  overflow: hidden;
}

.map-container {
  width: 100%;
  min-height: 450px;
  background: var(--report-bg);
}

:host ::ng-deep app-wwellmap {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 450px;
}

.map-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 1.25rem;
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--report-border);
  background: color-mix(in srgb, var(--report-value-bg) 96%, var(--accent) 4%);
}

.map-legend__item {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.map-legend__dot {
  width: 12px;
  height: 12px;
  border-radius: 3px;
  flex-shrink: 0;

  &--wasi      { background: var(--wasi-color); }
  &--ownership { background: var(--ownership-color); }
  &--aquifer   { background: var(--aquifer-color); }
  &--active    { background: var(--active-well-color); border-radius: 50%; }
}

.map-legend__text {
  color: var(--report-text);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.01em;
}

@media (max-width: 640px) {
  :host { padding: 1rem 0.5rem 2rem; }

  .report-shell { padding: 0.8rem; border-radius: 16px; }

  .report-header__title { font-size: 0.95rem; }

  .map-container { min-height: 300px; }

  :host ::ng-deep app-wwellmap { min-height: 300px; }

  .map-legend { flex-direction: column; gap: 0.5rem; }
}


