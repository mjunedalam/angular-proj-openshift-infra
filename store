  SEQ_GAP: animValue(_BASE.SEQ_GAP),
  // Legacy alias so depth-scale component keeps working unchanged
  OVERLAY_DELAY: animValue((_BASE.CASING_STAGGER * 3) + _BASE.CASING_DURATION + 100),
} as const;
