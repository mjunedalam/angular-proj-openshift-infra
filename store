  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
  margin-bottom: 1rem;
}

.wwell-map-eyebrow {
  margin: 0 0 0.25rem;
  color: var(--accent);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.wwell-map-title {
  margin: 0;
  color: var(--map-header-text);
  font-size: 1.4rem;
  font-weight: 700;
}

