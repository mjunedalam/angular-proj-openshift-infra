<div class="report-shell">
  <div class="report-header">
    <div class="report-header__bar">
      <span class="report-header__title">Daily Drilling Operations Summary</span>
    </div>
  </div>

  <div class="report-toolbar">
    <div class="date-picker-section">
      <label class="date-picker-label" for="report-date-input">Date:</label>
      <input
        id="report-date-input"
        type="date"
        class="date-picker-input"
        [ngModel]="selectedDateString"
        (ngModelChange)="onDateChange($event)"
        [max]="maxDateString"
        aria-label="Select report date"
      />
    </div>

    <button
      type="button"
      (click)="sendEmail()"
      class="email-btn"
      aria-label="Email report to me"
    >
      <span class="email-btn__shimmer"></span>
      <span class="email-btn__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="2" y="4" width="20" height="16" rx="3"/>
          <path d="m2 7 10 7 10-7"/>
        </svg>
      </span>
      <span class="email-btn__label">Email To Me</span>
      <span class="email-btn__arrow" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </span>
    </button>
  </div>

  @if (store.isLoading()) {
    <mat-progress-bar mode="indeterminate" class="report-loading-bar" />
  }

  <div id="report-content" class="report-content">
    @if (pageMessage()) {
      <div class="report-empty">
        <p>{{ pageMessage() }}</p>
      </div>
    } @else if (hasError()) {
      <div class="report-error">
        <p>Error ({{ statusCode() }}): {{ errorMessage() }}</p>
      </div>
    } @else {
      <!-- Water Well Test Results grid -->
      @if (waterWelltestResult().length) {
      <section class="report-section">
        <div class="report-section__heading">
          <span class="report-section__title">Water Well Test Results</span>
        </div>
        <div class="report-grid">
          @for (result of waterWelltestResult(); track result.wellName) {
            <div class="report-card report-card--test">
              <div class="card-header card-header--green">
                <span class="card-header__name">{{ result.wellName || 'Unknown' }}</span>
                <span class="card-header__badge">Test Result</span>
              </div>
              <table class="card-table">
                <tbody>
                  <tr>
                    <td class="card-table__label">Aquifer</td>
                    <td class="card-table__value" [class.missing]="!result.trgtRsvrCd">{{ result.trgtRsvrCd || 'Missing' }}</td>
                    <td class="card-table__label">Test Rate (GPM)</td>
                    <td class="card-table__value" [class.missing]="!result.testRate">{{ result.testRate || 'Missing' }}</td>
                  </tr>
                  <tr>
                    <td class="card-table__label">{{ result.testType === 'FLOW' ? 'SIWHP (PSI)' : 'RPM' }}</td>
                    <td class="card-table__value" [class.missing]="result.testType === 'FLOW' ? !result.siwhp : !result.rPM">
                      {{ result.testType === 'FLOW' ? (result.siwhp || 'Missing') : (result.rPM || 'Missing') }}
                    </td>
                    <td class="card-table__label">H2S (PPM)</td>
                    <td class="card-table__value" [class.missing]="!result.h2sPPM">{{ result.h2sPPM || 'Missing' }}</td>
                  </tr>
                  <tr>
                    <td class="card-table__label">Temperature (°C)</td>
                    <td class="card-table__value" [class.missing]="!result.temperature">{{ result.temperature || 'Missing' }}</td>
                    <td class="card-table__label">Well Productivity (GPM/ft)</td>
                    <td class="card-table__value" [class.missing]="!result.wellProductivity">{{ result.wellProductivity || 'Missing' }}</td>
                  </tr>
                  <tr>
                    <td class="card-table__label">TDS (PPM)</td>
                    <td class="card-table__value" [class.missing]="!result.tds">{{ result.tds || 'Missing' }}</td>
                    <td class="card-table__label"></td>
                    <td class="card-table__value"></td>
                  </tr>
                </tbody>
              </table>
            </div>
          }
        </div>
      </section>
      }

      <!-- Daily Drilling Summary grid -->
      <div class="report-grid">
        @for (report of morningReport(); track report.epANum) {
          <div class="report-card report-card--summary">

            <div class="card-header card-header--blue">
              <div class="card-header__left">
                <span class="card-header__name">{{ report.wGnrName }}</span>
                <span class="card-header__rig">{{ report.wRigCd }}</span>
              </div>
              <input
                class="card-header__status-input"
                [class.card-header__status-input--na]="report.rigStatus === 'NA'"
                placeholder="Rig status"
                [ngModel]="report.rigStatus"
                (ngModelChange)="store.updateRigStatus(report.epANum, $event)"
                name="rigStatus"
              />
            </div>

            <table class="card-table">
              <tbody>
                <tr>
                  <td class="card-table__label">Target Aquifer</td>
                  <td class="card-table__value" [class.missing]="!report.trgtRsvrCd" [class.present]="report.trgtRsvrCd">
                    {{ report.trgtRsvrCd || 'Missing' }}
                  </td>
                  <td class="card-table__label">Current Formation</td>
                  <td class="card-table__value" [class.missing]="!report.stLongCd" [class.present]="report.stLongCd">
                    {{ report.stLongCd || 'NA' }}
                  </td>
                </tr>
                <tr>
                  <td class="card-table__label">Current Depth (ft)</td>
                  <td class="card-table__value" [class.missing]="!report.wPrsntDpth" [class.present]="report.wPrsntDpth">
                    {{ report.wPrsntDpth || 'Missing' }}
                  </td>
                  <td class="card-table__label">Planned Total Depth (ft)</td>
                  <td class="card-table__value" [class.missing]="!report.plLtrlEndDpth" [class.present]="report.plLtrlEndDpth">
                    {{ report.plLtrlEndDpth || 'Missing' }}
                  </td>
                </tr>
                <tr>
                  <td class="card-table__label">Footage (ft)</td>
                  <td class="card-table__value" [class.missing]="!report.wDpthChgDis" [class.present]="report.wDpthChgDis">
                    {{ report.wDpthChgDis || 'Missing' }}
                  </td>
                  <td class="card-table__label">Supportings</td>
                  <td class="card-table__value" [class.missing]="!report.supportings" [class.present]="report.supportings">
                    {{ report.supportings || 'Missing' }}
                  </td>
                </tr>
                <tr>
                  <td class="card-table__label">Operation</td>
                  <td class="card-table__value card-table__value--op" colspan="3" [class.present]="report.wOpRmk">
                    {{ report.wOpRmk || 'XXXX' }}
                  </td>
                </tr>
              </tbody>
            </table>

          </div>
        }
      </div>

      <!-- Map -->
      <section class="report-map-section">
        <div class="map-container">
          <app-wwellmap #wwellMap ></app-wwellmap>
        </div>
        <div class="map-legend">
          <div class="map-legend__item">
            <span class="map-legend__dot map-legend__dot--wasi"></span>
            <span class="map-legend__text">WASI</span>
          </div>
          <div class="map-legend__item">
            <span class="map-legend__dot map-legend__dot--ownership"></span>
            <span class="map-legend__text">WELLS OWNERSHIP</span>
          </div>
          <div class="map-legend__item">
            <span class="map-legend__dot map-legend__dot--aquifer"></span>
            <span class="map-legend__text">Target Aquifer</span>
          </div>
          <div class="map-legend__item">
            <span class="map-legend__dot map-legend__dot--active"></span>
            <span class="map-legend__text">Active Well</span>
          </div>
        </div>
      </section>
    }
  </div>
</div>
