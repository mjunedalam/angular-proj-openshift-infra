package com.example.wells.resource;

import com.example.wells.dto.ApiResponse;
import com.example.wells.model.Well;
import com.example.wells.service.WellService;
import jakarta.inject.Inject;
import jakarta.ws.rs.*;
import jakarta.ws.rs.core.MediaType;

import java.util.List;

@Path("/api/wells")
@Produces(MediaType.APPLICATION_JSON)
public class WellResource {

    @Inject
    WellService wellService;

    @GET
    public ApiResponse<List<Well>> getWells(@QueryParam("date") String date) {
        return wellService.getWells(date);
    }
}
