  private getCasingTier(csg: ICasingIR, casings: ICasingIR[]): number {
    const structuralCasings = casings.filter(c => c.csgType !== 'Gravel Pack');
    const idx = structuralCasings.indexOf(csg);
    return idx === -1 ? 0 : idx;
  }

