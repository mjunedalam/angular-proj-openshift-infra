 PROCEDURE mr_wells
  (
   result_crs IN OUT result_crs_type,
   p_dt IN DATE 
  )
  IS
    
  BEGIN
    
        OPEN result_crs FOR
      SELECT d.ep_a_num, d.rac_num, w.w_gnr_name
        FROM drlg_op_status d
        LEFT JOIN rac r ON r.rac_num = d.rac_num
        LEFT JOIN well_master w ON d.ep_a_num = w.ep_a_num
       WHERE 1 = 1
         AND r.w_drlg_wtyp_cd IN ('WC', 'WC-O', 'WI', 'WP', 'WS', 'WSEV')
         AND UPPER(r.w_rig_cd) NOT LIKE '%LSTK%'
         AND (UPPER(r.drlg_plan_well_desc) LIKE '%WATER%' OR UPPER(r.drlg_plan_well_desc) LIKE '%WSW%')
         AND TRUNC(d.w_act_dt) = TRUNC(p_dt)
       ORDER By 1, 2;          
  
  END mr_wells;
