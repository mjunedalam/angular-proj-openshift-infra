// ── Container ──────────────────────────────────────────────────────────────────
.docs-container {
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

// ── Header (toggle button) ─────────────────────────────────────────────────────
.docs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  width: 100%;
  text-align: left;
  background: transparent;
  border: none;
  cursor: pointer;
  color: inherit;
  transition: background 150ms ease;

  &:hover { background: var(--accent-muted); }

  &__title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 17px;
    font-weight: 800;
    color: var(--text-primary);

    .icon-box {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent-muted);
      border-radius: 8px;
      color: var(--accent);
      flex-shrink: 0;

      svg { width: 16px; height: 16px; }
    }
  }

  &__right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  &__badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px 3px 7px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
    line-height: 1.5;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.18), rgba(134, 239, 172, 0.08));
    color: #166534;
    border: 1px solid rgba(34, 197, 94, 0.32);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.12);

    &::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 6px rgba(34, 197, 94, 0.7);
      animation: badge-pulse 2s ease-in-out infinite;
      flex-shrink: 0;
    }
  }
}

// ── Chevron ────────────────────────────────────────────────────────────────────
.chevron {
  width: 16px;
  height: 16px;
  color: var(--text-primary);
  transition: transform 260ms cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;

  &--open { transform: rotate(180deg); }
}

// ── Body (collapsible section) ─────────────────────────────────────────────────
.docs-state,
.docs-list {
  padding: 0 20px 20px;
}

// ── States ─────────────────────────────────────────────────────────────────────
.docs-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding-top: 24px;
  color: var(--text-secondary);
  font-size: 14px;
  font-weight: 700;
  opacity: 0.9;

  .state-icon { width: 28px; height: 28px; opacity: 0.75; }

  &--error { color: var(--danger); opacity: 1; }
  &--empty .state-icon { opacity: 0.3; }
}

// ── Document list ─────────────────────────────────────────────────────────────
.docs-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.doc-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 14px;
  background: var(--bg-surface);
  border: 1px solid var(--border-sub);
  border-radius: var(--radius-inner);
  cursor: pointer;
  width: 100%;
  text-align: left;
  transition: background 0.22s ease, border-color 0.22s ease,
              transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.22s ease;

  &:hover {
    background: var(--accent-muted);
    border-color: var(--accent);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(14, 165, 233, 0.12);

    .view-btn { opacity: 1; color: var(--accent); }
  }
}

// Type icon bubble
.doc-row__icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;

  svg { width: 16px; height: 16px; }

  &[data-type='pdf']   { background: rgba(239, 68, 68, 0.1);   color: #ef4444; }
  &[data-type='image'] { background: rgba(34, 197, 94, 0.1);   color: #22c55e; }
  &[data-type='excel'] { background: rgba(34, 197, 94, 0.12);  color: #16a34a; }
  &[data-type='word']  { background: rgba(59, 130, 246, 0.1);  color: #3b82f6; }
  &[data-type='other'] { background: rgba(148, 163, 184, 0.1); color: #94a3b8; }
}

.doc-row__title {
  flex: 1;
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doc-row__actions {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
  opacity: 0;
  transition: opacity 0.22s ease;
}

.action-btn {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  border: none;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease;

  mat-icon { font-size: 16px; width: 16px; height: 16px; line-height: 16px; }

  &--view {
    background: var(--accent-muted);
    color: var(--accent);
    &:hover { background: var(--accent); color: #fff; }
  }

  &--download {
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
    &:hover { background: #16a34a; color: #fff; }
  }

  &--loading {
    cursor: default;
    pointer-events: none;
    opacity: 0.6;
  }
}

.doc-row:hover .doc-row__actions { opacity: 1; }

@keyframes badge-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.45; transform: scale(0.75); }
}

