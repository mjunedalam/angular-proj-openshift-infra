// ── Uploaded row state ────────────────────────────────────────────────────────
.file-row--uploaded {
  background: #f0fdf4;
  border-color: #bbf7d0;

  &:hover {
    border-color: #86efac;
    box-shadow: 0 1px 6px rgba(22, 163, 74, 0.1);
  }

  .file-row__name { color: #15803d; }
}

.file-row__type-icon--done {
  color: #16a34a !important;
}

.file-uploaded-badge {
  font-size: 0.56rem;
  font-weight: 700;
  padding: 0.1rem 0.3rem;
  border-radius: 4px;
  background: #dcfce7;
  color: #15803d;
  border: 1px solid #86efac;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  line-height: 1.4;
