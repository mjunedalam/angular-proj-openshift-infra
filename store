import { isPlatformBrowser } from '@angular/common';
import {
  ChangeDetectionStrategy,
  Component,
  computed,
  effect,
  ElementRef,
  inject,
  OnDestroy,
  OnInit,
  PLATFORM_ID,
  signal,
  ViewChild,
} from '@angular/core';
import { MatCardModule } from '@angular/material/card';
import Graphic from '@arcgis/core/Graphic';
import Point from '@arcgis/core/geometry/Point';
import GraphicsLayer from '@arcgis/core/layers/GraphicsLayer';
import PictureMarkerSymbol from '@arcgis/core/symbols/PictureMarkerSymbol';
import SimpleMarkerSymbol from '@arcgis/core/symbols/SimpleMarkerSymbol';
import TextSymbol from '@arcgis/core/symbols/TextSymbol';
import { watch } from '@arcgis/core/core/reactiveUtils';

import { DrillingDataStore } from '@store/drilling-data/drilling-data.store';
import { LoaderService } from '@shared/components/global-loader/loader.service';
import { ExternalConfigService } from '@shared/services/external-config.service';
import { MAP_CONFIG, STYLE } from 'src/app/shared/models/config/agwa-map.config';

const BOOT_TASK = 'arcgis-map';
const SELECTED_WELL_LAYER_ID = 'selected-wwell';
const KSA_BOUNDARY_LAYER_ID = 'ksa-boundary';
const SELECTED_WELL_ZOOM = 10;

interface SelectedWellLocation {
  readonly epANum: number;
  readonly wellName: string;
  readonly targetAquifer: string;
  readonly lat: number;
  readonly lng: number;
}

@Component({
  selector: 'app-active-wwell-map',
  standalone: true,
  imports: [MatCardModule],
  templateUrl: './active-wwell-map.component.html',
  styleUrl: './active-wwell-map.component.scss',
  changeDetection: ChangeDetectionStrategy.OnPush,
})
export class ActiveWwellMapComponent implements OnInit, OnDestroy {
  @ViewChild('presMapViewNode', { static: true }) private mapViewEl?: ElementRef<HTMLDivElement>;

  private readonly platformId = inject(PLATFORM_ID);
  private readonly store = inject(DrillingDataStore);
  private readonly extConfig = inject(ExternalConfigService);
  private readonly loader = inject(LoaderService);

  private mapView?: __esri.MapView;
  private selectedWellLayer?: GraphicsLayer;
  private stationaryWatchHandle?: __esri.WatchHandle;
  private resizeObserver?: ResizeObserver;
  private bootRegistered = false;

  protected readonly errorMessage = signal<string | null>('Select a well to preview its location.');
  protected readonly mapReady = signal(false);

  private readonly selectedWellLocation = computed<SelectedWellLocation | null>(() => {
    const header = this.store.wellHeaderData();
    const epANum = this.store.selectedEpANum();

    if (!header || epANum === null) {
      return null;
    }

    const lat = this.parseCoordinate(header.lat);
    const lng = this.parseCoordinate(header.lon);

    if (lat === null || lng === null) {
      return null;
    }

    return {
      epANum,
      wellName: header.wellName,
      targetAquifer: header.targetedAquifer,
      lat,
      lng,
    };
  });

  constructor() {
    effect(() => {
      const selectedWell = this.selectedWellLocation();

      if (!this.mapReady()) {
        return;
      }

      this.syncSelectedWellGraphic(selectedWell);
    });
  }

  ngOnInit(): void {
    if (!isPlatformBrowser(this.platformId)) {
      return;
    }

    this.registerBoot();
    void this.initMap();
  }

  ngOnDestroy(): void {
    this.stationaryWatchHandle?.remove();
    this.resizeObserver?.disconnect();
    this.mapView?.destroy();
    this.resolveBoot();
  }

  async captureMapAsBase64(): Promise<string | undefined> {
    if (!this.mapView) {
      return undefined;
    }

    await this.waitForMapRender();
    return this.getScreenshotBase64();
  }

  async saveMapImage(): Promise<void> {
    const base64 = await this.captureMapAsBase64();

    if (!base64) {
      return;
    }

    const anchor = document.createElement('a');
    anchor.href = `data:image/png;base64,${base64}`;
    anchor.download = 'active-selected-well-map.png';
    document.body.appendChild(anchor);
    anchor.click();
    document.body.removeChild(anchor);
  }

  private parseCoordinate(value: number | string | null | undefined): number | null {
    const numericValue = typeof value === 'number'
      ? value
      : Number.parseFloat(String(value ?? '').trim());

    return Number.isFinite(numericValue) ? numericValue : null;
  }

  private async initMap(): Promise<void> {
    try {
      const [{ default: WebMapMod }, { default: MapViewMod }, { default: FeatureLayerMod }, { default: esriCfg }] =
        await Promise.all([
          import('@arcgis/core/WebMap'),
          import('@arcgis/core/views/MapView'),
          import('@arcgis/core/layers/FeatureLayer'),
          import('@arcgis/core/config'),
        ]);

      const { useMockMap, esriUrl, webMapItemId, mockWebMapItemId } = this.extConfig.settings;
      const itemId = useMockMap ? mockWebMapItemId : webMapItemId;

      if (!useMockMap && esriUrl) {
        esriCfg.portalUrl = esriUrl;
      }

      const webMap = new WebMapMod({
        portalItem: { id: itemId },
      });

      this.mapView = new MapViewMod({
        container: this.mapViewEl?.nativeElement,
        map: webMap,
        center: MAP_CONFIG.center,
        zoom: MAP_CONFIG.zoom,
        constraints: {
          minZoom: MAP_CONFIG.minZoom,
          maxZoom: MAP_CONFIG.maxZoom,
        },
        ui: {
          components: [],
        },
      });

      await this.mapView.when();

      const ksaBoundary = new FeatureLayerMod({
        id: KSA_BOUNDARY_LAYER_ID,
        url: 'https://services.arcgis.com/P3ePLMYs2RVChkJx/arcgis/rest/services/World_Countries_(Generalized)/FeatureServer/0',
        definitionExpression: "COUNTRY = 'Saudi Arabia'",
        renderer: {
          type: 'simple',
          symbol: {
            type: 'simple-fill',
            color: [255, 200, 0, 0.04],
            outline: {
              type: 'simple-line',
              color: [255, 165, 0, 0.7],
              width: 1.5,
              style: 'dash',
            },
          },
        } as __esri.SimpleRendererProperties & { type: 'simple' },
        title: 'KSA Boundary',
      });

      this.selectedWellLayer = new GraphicsLayer({
        id: SELECTED_WELL_LAYER_ID,
      });

      webMap.addMany([ksaBoundary, this.selectedWellLayer]);

      this.mapReady.set(true);
      this.setupResizeObserver();

      this.stationaryWatchHandle = watch(
        () => this.mapView?.stationary ?? false,
        (isStationary) => {
          if (isStationary) {
            const selectedWell = this.selectedWellLocation();
            if (selectedWell) {
              void this.focusSelectedWell(new Point({
                latitude: selectedWell.lat,
                longitude: selectedWell.lng,
              }));
            }
          }
        },
      );

      await this.waitForMapRender();
      this.syncSelectedWellGraphic(this.selectedWellLocation());
      this.resolveBoot();
    } catch (error) {
      console.error('[ActiveWwellMap] initMap error', error);
      this.errorMessage.set('Map could not be initialized.');
      this.resolveBoot();
    }
  }

  private setupResizeObserver(): void {
    const container = this.mapViewEl?.nativeElement;

    if (!container || typeof ResizeObserver === 'undefined') {
      return;
    }

    this.resizeObserver?.disconnect();
    this.resizeObserver = new ResizeObserver(() => {
      requestAnimationFrame(() => {
        const selectedWell = this.selectedWellLocation();
        if (selectedWell) {
          void this.focusSelectedWell(new Point({
            latitude: selectedWell.lat,
            longitude: selectedWell.lng,
          }));
        }
      });
    });

    this.resizeObserver.observe(container);
  }

  private syncSelectedWellGraphic(selectedWell: SelectedWellLocation | null): void {
    if (!this.selectedWellLayer) {
      return;
    }

    this.selectedWellLayer.removeAll();

    if (this.store.selectedEpANum() === null) {
      this.errorMessage.set('Select a well to preview its location.');
      return;
    }

    if (!selectedWell) {
      this.errorMessage.set('Selected well does not have valid latitude/longitude data.');
      return;
    }

    this.errorMessage.set(null);

    const point = new Point({
      latitude: selectedWell.lat,
      longitude: selectedWell.lng,
    });

    const haloGraphic = new Graphic({
      geometry: point,
      symbol: new SimpleMarkerSymbol({
        style: 'circle',
        size: 34,
        color: [14, 165, 233, 0.14],
        outline: {
          color: [14, 165, 233, 0.95],
          width: 2.5,
        },
      }),
    });

    const iconGraphic = new Graphic({
      geometry: point,
      symbol: new PictureMarkerSymbol({
        url: STYLE.markerIcon,
        width: STYLE.markerSize,
        height: STYLE.markerSize,
      }),
    });

    const labelGraphic = new Graphic({
      geometry: point,
      symbol: new TextSymbol({
        text: `${selectedWell.epANum} • ${selectedWell.wellName}`,
        color: [255, 255, 255],
        font: {
          size: 12,
          weight: 'bold',
          family: 'DM Sans, sans-serif',
        },
        haloColor: [5, 11, 24, 0.96],
        haloSize: 1.5,
        xoffset: 0,
        yoffset: -26,
        horizontalAlignment: 'center',
        verticalAlignment: 'bottom',
      }),
    });

    this.selectedWellLayer.addMany([haloGraphic, iconGraphic, labelGraphic]);
    void this.focusSelectedWell(point);
  }

  private async focusSelectedWell(point: Point): Promise<void> {
    if (!this.mapView) {
      return;
    }

    try {
      await this.mapView.goTo(
        {
          target: point,
          zoom: SELECTED_WELL_ZOOM,
        },
        {
          animate: false,
        },
      );
    } catch {
      // Ignore goTo interruptions during rapid state changes or teardown.
    }
  }

  private async waitForMapRender(): Promise<void> {
    if (!this.mapView) {
      return;
    }

    if (!this.mapView.updating) {
      await new Promise(requestAnimationFrame);
      return;
    }

    await new Promise<void>((resolve) => {
      const handle = watch(
        () => this.mapView?.updating ?? false,
        (updating) => {
          if (!updating) {
            handle.remove();
            requestAnimationFrame(() => resolve());
          }
        },
      );
    });
  }

  private async getScreenshotBase64(): Promise<string> {
    const screenshot = await this.mapView!.takeScreenshot({ format: 'png', quality: 1 });
    const [, raw] = screenshot.dataUrl.split(',');

    if (!raw) {
      throw new Error('Screenshot payload empty');
    }

    const img = new Image();
    img.src = `data:image/png;base64,${raw}`;
    await new Promise((resolve, reject) => {
      img.onload = resolve;
      img.onerror = reject;
    });

    const canvas = document.createElement('canvas');
    canvas.width = img.width;
    canvas.height = img.height;
    canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);

    return canvas.toDataURL('image/jpeg', 1).split(',')[1];
  }

  private registerBoot(): void {
    if (this.bootRegistered) {
      return;
    }

    this.bootRegistered = true;
    this.loader.registerBootTask(BOOT_TASK);
  }

  private resolveBoot(): void {
    if (!this.bootRegistered) {
      return;
    }

    this.bootRegistered = false;
    this.loader.resolveBootTask(BOOT_TASK);
  }
}
