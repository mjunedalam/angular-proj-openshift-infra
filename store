          .attr('text-anchor', 'middle')
          .style('opacity', 0)
          .text(`${csg.csgSize}"`)
          .transition().delay(labelsStart).duration(250).style('opacity', 1);
      }
      lg.transition().delay(labelsStart).duration(300).ease(easeCubicInOut).style('opacity', 1);
    });
