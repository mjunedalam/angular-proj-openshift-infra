package com.example.wells.mapper;

import com.example.wells.model.Well;
import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;

import java.util.Date;
import java.util.List;
import java.util.Map;

/**
 * MyBatis mapper for the MR_WELLS Oracle stored procedure.
 *
 * The procedure opens a SYS_REFCURSOR; MyBatis handles the cursor
 * via a resultMap defined in WellMapper.xml (statementType=CALLABLE).
 */
@Mapper
public interface WellMapper {

    /**
     * Calls:  { call mr_wells( #{resultCrs, mode=OUT, jdbcType=CURSOR,
     *                                      javaType=ResultSet, resultMap=wellResultMap},
     *                          #{pDt, mode=IN, jdbcType=DATE} ) }
     *
     * MyBatis populates the map with key "resultCrs" as a List<Well>
     * after the cursor is consumed.
     *
     * @param params  mutable Map with entry "pDt" → java.util.Date (IN)
     *                After the call the map will also contain "resultCrs" → List<Well>
     */
    void callMrWells(Map<String, Object> params);
}
