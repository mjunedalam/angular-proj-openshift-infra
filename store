package com.example.wells.model;

import com.fasterxml.jackson.annotation.JsonProperty;

/**
 * Maps to the SELECT columns returned by the mr_wells cursor:
 *   d.ep_a_num, d.rac_num, w.w_gnr_name
 */
public class Well {

    @JsonProperty("epANum")
    private String epANum;

    @JsonProperty("racNum")
    private String racNum;

    @JsonProperty("wGnrName")
    private String wGnrName;

    /* ── constructors ─────────────────────────────────────── */

    public Well() {}

    public Well(String epANum, String racNum, String wGnrName) {
        this.epANum   = epANum;
        this.racNum   = racNum;
        this.wGnrName = wGnrName;
    }

    /* ── getters / setters ───────────────────────────────── */

    public String getEpANum()               { return epANum;   }
    public void   setEpANum(String v)       { this.epANum = v; }

    public String getRacNum()               { return racNum;   }
    public void   setRacNum(String v)       { this.racNum = v; }

    public String getWGnrName()             { return wGnrName;   }
    public void   setWGnrName(String v)     { this.wGnrName = v; }

    @Override
    public String toString() {
        return "Well{epANum='" + epANum + "', racNum='" + racNum
                + "', wGnrName='" + wGnrName + "'}";
    }
}
