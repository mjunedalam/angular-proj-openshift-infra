        .attr('class', 'geo-code')
        .attr('x', geoLineX + 18)
        .attr('dy', '0.35em')
        .text(top.stLongCd);

      g.transition()
        .delay(ANIM.GEO_DELAY + idx * ANIM.GEO_STAGGER)
        .duration(220)
