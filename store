package com.example.wells.service;

import com.example.wells.mapper.WellMapper;
import com.example.wells.model.Well;
import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import org.jboss.logging.Logger;

import java.time.LocalDate;
import java.time.ZoneId;
import java.util.Date;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

/**
 * Service layer that calls the mr_wells stored procedure and returns results.
 */
@ApplicationScoped
public class WellService {

    private static final Logger LOG = Logger.getLogger(WellService.class);

    @Inject
    WellMapper wellMapper;

    /**
     * Retrieves wells active on the given date by delegating to
     * the mr_wells Oracle stored procedure.
     *
     * @param date  the operational date to filter on (maps to p_dt IN DATE)
     * @return      list of Well records from the procedure cursor
     */
    @SuppressWarnings("unchecked")
    public List<Well> getWells(LocalDate date) {
        LOG.debugf("Calling mr_wells for date: %s", date);

        // Convert LocalDate → java.util.Date (Oracle DATE)
        Date oracleDate = Date.from(date.atStartOfDay(ZoneId.systemDefault()).toInstant());

        // Build the parameter map; MyBatis populates "resultCrs" after the call
        Map<String, Object> params = new HashMap<>();
        params.put("pDt", oracleDate);

        wellMapper.callMrWells(params);

        List<Well> results = (List<Well>) params.get("resultCrs");
        LOG.debugf("mr_wells returned %d row(s)", results == null ? 0 : results.size());

        return results == null ? List.of() : results;
    }
}
