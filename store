.wwell-map-legend__chip--green {
  background: #84cc16;
}

.wwell-map-legend__chip--purple {
  background: #c084fc;
}

.wwell-map-legend__chip--red {
  background: #f87171;
}

.wwell-map-legend__chip--blue {
  background: #60a5fa;
}

