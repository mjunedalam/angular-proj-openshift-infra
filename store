<div class="active-wwell-page">
  <div
    class="active-wwell-loading-slot"
    [class.active-wwell-loading-slot--active]="store.isDetailsLoading()"
  >
    <mat-progress-bar
      mode="indeterminate"
      class="active-wwell-loading-bar"
    ></mat-progress-bar>
  </div>

  <div class="active-wwell-shell">
    <div class="active-wwell-sidebar">
      <div class="well-header well-list">Wells List</div>

      <mat-chip-listbox class="mat-mdc-chip-set-stacked">
        @for (well of wells(); track well.epANum) {
          <mat-chip-option
            [selected]="store.selectedEpANum() === well.epANum"
            [ngClass]="{
              'well-selected': store.selectedEpANum() === well.epANum,
            }"
            (click)="onWellSelect(well.epANum)"
          >
            {{ well.wellName }}
          </mat-chip-option>
        }
      </mat-chip-listbox>

      <div class="active-wwell-sidebar__dept">
        Wellsite &amp; Water Operation Department
      </div>
    </div>

    <div class="active-wwell-content">
      <div class="aw-page-header">
        <div class="aw-date-picker">
          <label class="aw-date-label" for="aw-date-input">Date:</label>
          <input
            id="aw-date-input"
            type="date"
            class="aw-date-input"
            [ngModel]="selectedDateString()"
            [max]="maxDateString"
            (ngModelChange)="onDateChange($event)"
            aria-label="Select date for well data"
          />
        </div>
        <div class="well-header">Single Water Well Review</div>
        <div class="aw-header-spacer"></div>
      </div>

      <div class="active-wwell-grid">
        <div class="active-wwell-main">
          <app-wwell-header></app-wwell-header>
          <app-database-info></app-database-info>
          <app-operation-summary></app-operation-summary>

          <div class="aw-section">
            <div class="well-header">Drilling Remarks</div>
            <textarea
              class="active-wwell-remarks"
              readonly
              [value]="drillingRemarks()"
            ></textarea>
          </div>

          <app-formation-tops-and-casing></app-formation-tops-and-casing>
          <app-casing-info></app-casing-info>
          <app-wwell-test></app-wwell-test>
        </div>

        <div class="active-wwell-sidepanel">
          <app-file-upload></app-file-upload>

          <div class="lt-orange active-wwell-status-panel">
            <mat-form-field
              appearance="outline"
              subscriptSizing="dynamic"
              class="active-wwell-select"
            >
              <mat-label>Status</mat-label>
              <mat-select
                [ngModel]="selectedStatus()"
                (ngModelChange)="onSelect($event)"
                panelClass="status-select-panel"
                (openedChange)="onStatusPanelToggle($event)"
              >
                <mat-option disabled class="status-search-opt">
                  <div class="status-search-wrap">
                    <mat-icon class="status-search-icon">search</mat-icon>
                    <input
                      class="status-search-input"
                      placeholder="Search status…"
                      autocomplete="off"
                      [ngModel]="statusSearchQuery()"
                      (ngModelChange)="statusSearchQuery.set($event)"
                      (click)="$event.stopPropagation()"
                      (keydown)="
                        $event.key !== 'Escape' && $event.stopPropagation()
                      "
                    />
                  </div>
                </mat-option>

                @if (filteredStatusOptions().length === 0) {
                  <mat-option disabled class="status-no-results"
                    >No results</mat-option
                  >
                }

                @for (status of filteredStatusOptions(); track status) {
                  <mat-option [value]="status">{{ status }}</mat-option>
                }
                <mat-option [value]="ADD_NEW_SENTINEL">
                  <mat-icon inline>add</mat-icon>
                  Add new...
                </mat-option>
              </mat-select>
            </mat-form-field>

            <mat-form-field
              appearance="outline"
              subscriptSizing="dynamic"
              class="active-wwell-select"
            >
              <mat-label>Area</mat-label>
              <mat-select
                [ngModel]="selectedArea()"
                (ngModelChange)="onAreaChange($event)"
              >
                @for (area of areas; track area.value) {
                  <mat-option [value]="area.value">{{ area.value }}</mat-option>
                }
              </mat-select>
            </mat-form-field>

            <div class="active-wwell-stat-box">
              <mat-label>Formation Drilling</mat-label>
              <div class="stat-value">
                {{ displayValue(summaryStats().formationDrilling) }}
              </div>
            </div>

            <div class="active-wwell-stat-box">
              <mat-label>Bit Size</mat-label>
              <div class="stat-value">
                {{ displayValue(summaryStats().bitSize) }}
              </div>
            </div>

            <div class="active-wwell-stat-box">
              <mat-label>Circulation</mat-label>
              <div class="stat-value">
                {{ displayValue(summaryStats().circulation) }}
              </div>
            </div>

            <div class="active-wwell-stat-box">
              <mat-label>Mud Weight</mat-label>
              <div class="stat-value">
                {{ displayValue(summaryStats().mudWeight) }}
              </div>
            </div>

            <div class="active-wwell-stat-box avg-rop-box">
              <mat-label>Avg ROP</mat-label>
              <div class="stat-value">
                {{ displayValue(summaryStats().avgRop) }}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="active-wwell-footer">
    <div class="footer-copy">Saudi Aramco Company General Use</div>
    <div class="footer-legend">
      <span class="footer-legend__title">Data Source Legend</span>
      <div class="footer-legend__grid">
        <div class="footer-legend__item">
          <div class="legend-swatch legend-swatch--gray"></div>
          Drill Eye
        </div>
        <div class="footer-legend__item">
          <div class="legend-swatch legend-swatch--orange"></div>
          GIS
        </div>
        <div class="footer-legend__item">
          <div class="legend-swatch legend-swatch--blue"></div>
          IR
        </div>
      </div>
    </div>
  </div>
</div>
==
:host {
  display: block;
}

.active-wwell-page {
  width: min(100%, 1600px);
  margin: 0 auto;
  border: 2px solid #93c5fd;
  background: #fff;
  font-family: var(--font-sans);
}

.active-wwell-loading-slot {
  height: 4px;
  opacity: 0;
  transition: opacity 0.18s ease;
  pointer-events: none;

  &--active {
    opacity: 1;
  }
}

:host ::ng-deep .active-wwell-loading-bar {
  height: 4px;
  --mdc-linear-progress-track-height: 4px;
  --mdc-linear-progress-active-indicator-height: 4px;
  --mdc-linear-progress-track-color: rgba(59, 130, 246, 0.12);
  --mdc-linear-progress-active-indicator-color: transparent;
}

:host ::ng-deep .active-wwell-loading-bar .mdc-linear-progress__bar-inner {
  border-top: none !important;
  height: 4px;
  background: linear-gradient(to right, #2563eb, #38bdf8);
}

// ── Shell ─────────────────────────────────────────────────────────────────────
.active-wwell-shell {
  display: flex;
  align-items: stretch;
}

// ── Sidebar ───────────────────────────────────────────────────────────────────
.active-wwell-sidebar {
  width: 11rem;
  min-width: 11rem;
  flex: 0 0 11rem;
  background: #f3f4f6;
  border-right: 1px solid #e5e7eb;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  padding: 0.45rem;
}

.well-list {
  font-size: 14px;
  font-weight: 600;
  line-height: 1.35;
  margin-bottom: 2px;
  padding: 8px 10px;
}

.active-wwell-sidebar__dept {
  margin-top: auto;
  padding: 0.75rem 0.35rem 0.35rem;
  line-height: 1.45;
  font-size: 0.88rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: #374151;
}

:host ::ng-deep .active-wwell-sidebar .mat-mdc-chip-set {
  margin: 0;
}
:host ::ng-deep .active-wwell-sidebar .mdc-evolution-chip-set__chips {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
:host ::ng-deep .active-wwell-sidebar .mat-mdc-chip-option {
  min-height: 2rem;
  border-radius: 0.45rem;
  justify-content: flex-start;
  font-size: 0.92rem;
  font-weight: 600;
  line-height: 1.45;
}

// ── Content ───────────────────────────────────────────────────────────────────
.active-wwell-content {
  flex: 1 1 auto;
  min-width: 0;
  padding: 0.5rem;
}

.active-wwell-content > .aw-page-header .well-header {
  font-size: 1rem;
  font-weight: 800;
  line-height: 1.35;
  color: #fff;
  text-align: center;
  justify-self: center;
}

.active-wwell-main > .aw-section .well-header {
  font-size: 1rem;
  font-weight: 800;
  line-height: 1.35;
}

.active-wwell-main > .aw-section {
  border-radius: 12px;
  overflow: hidden;
}

.aw-page-header {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  background: #2563eb;
  border-radius: 8px;
  padding: 0.45rem 0.75rem;
  margin-bottom: 0.5rem;
}

.aw-header-spacer {
  justify-self: end;
}

.aw-date-picker {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  justify-self: start;
}

.aw-date-label {
  font-size: 0.88rem;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}

.aw-date-input {
  font-size: 0.88rem;
  font-weight: 500;
  font-family: inherit;
  color: #1f2937;
  background: #f9fafb;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  padding: 0.3rem 0.5rem;
  cursor: pointer;
  outline: none;
  transition: border-color 0.15s ease;

  &:focus {
    border-color: #3b82f6;
    background: #fff;
  }
}

// ── Two-column grid ────────────────────────────────────────────────────────────
.active-wwell-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 19rem;
  gap: 0.75rem;
  align-items: start;
}


// ── Two-column grid ────────────────────────────────────────────────────────────
.active-wwell-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 19rem;
  gap: 0.75rem;
  align-items: start;
}

.active-wwell-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

// ── Side panel ────────────────────────────────────────────────────────────────
.active-wwell-sidepanel {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.lt-orange {
  background: rgb(134 205 234);
}

.active-wwell-status-panel {
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 12px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
  padding: 0.55rem;
  align-content: start;
}

.active-wwell-stat-box {
  min-height: 3.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.2rem;
  padding: 0.45rem 0.55rem;
  border: 1px solid rgba(15, 23, 42, 0.12);
  border-radius: 10px;
  background: #dfe4e8;
}

.active-wwell-stat-box mat-label {
  font-size: 0.88rem;
  font-weight: 700;
  color: #334155;
  line-height: 1.35;
  letter-spacing: 0.02em;
}

.stat-value {
  font-size: 1.06rem;
  font-weight: 800;
  line-height: 1.35;
  color: #1e293b;
}

.avg-rop-box {
  grid-column: 1 / -1;
  text-align: center;
  align-items: center;
}

// ── Select fields ─────────────────────────────────────────────────────────────
.active-wwell-select {
  font-size: 0.98rem;
  width: 100%;
  grid-column: 1 / -1;
}

:host ::ng-deep .active-wwell-select .mat-mdc-form-field-subscript-wrapper { display: none; }
:host ::ng-deep .active-wwell-select .mat-mdc-text-field-wrapper {
  min-height: 2.4rem;
  padding-left: 0.45rem;
  padding-right: 0.45rem;
  background-color: #fff !important;
}
:host ::ng-deep .active-wwell-select .mat-mdc-form-field-infix {
  min-height: auto;
  padding-top: 0.65rem;
  padding-bottom: 0.45rem;
}
:host ::ng-deep .active-wwell-select .mat-mdc-select-value-text,
:host ::ng-deep .active-wwell-select .mat-mdc-floating-label {
  font-size: 0.94rem;
  font-weight: 600;
  letter-spacing: 0.01em;
}

@media (max-width: 1100px) {
  .active-wwell-grid {
    grid-template-columns: 1fr;
  }
}

// ── Drilling remarks ──────────────────────────────────────────────────────────
.active-wwell-remarks {
  display: block;
  width: 100%;
  box-sizing: border-box;
  height: 5rem;
  resize: none;
  font-size: 1.02rem;
  font-weight: 600;
  line-height: 1.6;
  padding: 0.6rem 0.7rem;
  border: none;
  font-family: inherit;
  color: #1f2937;
}

// ── Footer ────────────────────────────────────────────────────────────────────
.active-wwell-footer {
  border-top: 1px solid #d1d5db;
  padding: 0.4rem 0.75rem;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  background: #f9fafb;
}

.footer-copy {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #9ca3af;
}

.footer-legend {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.footer-legend__title {
  font-weight: 600;
  font-style: italic;
  font-size: 0.9rem;
  color: #4b5563;
  margin-right: 0.5rem;
}

.footer-legend__grid {
  display: grid;
  grid-template-columns: repeat(2, auto);
  gap: 0.3rem 0.75rem;
}

.footer-legend__item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.84rem;
  line-height: 1.4;
  color: #4b5563;
}

.legend-swatch {
  width: 2rem;
  height: 0.9rem;

  &--gray   { background: #6b7280; }
  &--orange { background: #f97316; }
  &--blue   { background: #60a5fa; }
}

// ── Responsive ────────────────────────────────────────────────────────────────
@media (max-width: 1200px) {
  .active-wwell-grid { grid-template-columns: minmax(0, 1fr) 13rem; }
}

@media (max-width: 960px) {
  .active-wwell-shell { flex-direction: column; }

  .active-wwell-sidebar {
    width: 100%;
    min-width: 100%;
    flex-basis: auto;
    border-right: none;
    border-bottom: 1px solid #e5e7eb;
  }

  .active-wwell-grid { grid-template-columns: 1fr; }

  .active-wwell-footer {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }
}

// ── Mat-select panel — solid background fix (CDK overlay, outside component DOM)
::ng-deep .mat-mdc-select-panel {
  background: #ffffff !important;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18) !important;
}

::ng-deep .mat-mdc-option {
  font-size: 0.95rem !important;
  font-weight: 600 !important;
  color: #1f2937 !important;
  min-height: 2.4rem !important;

  &:hover:not(.mdc-list-item--disabled),
  &.mat-mdc-option-active {
    background: rgba(14, 165, 233, 0.1) !important;
  }
}

// ── Status search option ───────────────────────────────────────────────────────
.status-select-panel {
  padding-top: 0 !important;
  overflow-y: auto !important;
  display: flex !important;
  flex-direction: column !important;
}

.status-search-opt {
  opacity: 1 !important;
  cursor: default !important;
  padding: 0 !important;
  height: auto !important;
  min-height: unset !important;
  border-bottom: 1px solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 1;
  background: #fff;
  pointer-events: auto !important;

  &:hover {
    background: #fff !important;
  }

  /* override Material's disabled-state overrides on inner content */
  .mdc-list-item__primary-text {
    width: 100%;
    opacity: 1 !important;
    color: #1f2937 !important;
    pointer-events: auto !important;
  }

  /* Material adds this class on disabled options */
  &.mdc-list-item--disabled {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
}

.status-search-icon {
  font-size: 1rem;
  width: 1rem;
  height: 1rem;
  line-height: 1rem;
  color: #9ca3af;
  flex-shrink: 0;
  overflow: visible;
}

.status-search-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 0.88rem;
  font-weight: 500;
  color: #1f2937 !important;
  background: transparent;
  font-family: inherit;
  min-width: 0;
  pointer-events: auto !important;
  cursor: text !important;
  opacity: 1 !important;

  &::placeholder {
    color: #9ca3af;
    font-weight: 400;
  }
}

.status-no-results {
  font-size: 0.85rem !important;
  font-weight: 500 !important;
  color: #9ca3af !important;
  font-style: italic;
  text-align: center;
  justify-content: center;
}
.status-search-wrap {
 position: relative;
  z-index: 1;
  background: #fff;
  padding: 8px;
  border-bottom: 1px solid #e5e7eb;
}
