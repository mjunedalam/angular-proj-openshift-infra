<div class="test-results-container">
  <!-- ── Section header ── -->
  <div class="results-header">
    <div class="results-header__title">
      <div class="icon-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <span>Well Test Results</span>
    </div>
    <div class="results-header__badge">{{ store.wellTestResults().length }}</div>
  </div>

  <!-- ── List of results ── -->
  <div class="results-list">
    @for (result of store.wellTestResults(); track result.wellName; let i = $index) {
      <button @resultTabAnim class="result-tab" (click)="openDialog(result)">
        <div class="result-tab__left">
          <div class="well-indicator">
            <svg viewBox="0 0 24 24" fill="url(#res-drop-grad)">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
            </svg>
          </div>
          <div class="well-details">
            <div class="name">{{ result.wellName }}</div>
            <div class="aquifer">{{ result.aquifer }} Aquifer</div>
          </div>
        </div>

        <div class="result-tab__right">
          <div class="main-stat">
            <span class="val">{{ result.flowRate | number }}</span>
            <span class="unit">GPM</span>
          </div>
          <div class="view-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </div>
        </div>
      </button>
    }

    @if (store.wellTestResults().length === 0) {
      <div class="results-empty">No test records available.</div>
    }
  </div>
</div>

<svg style="width:0;height:0;position:absolute;" aria-hidden="true">
  <defs>
    <linearGradient id="res-drop-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#0ea5e9"/>
      <stop offset="100%" stop-color="#0369a1"/>
    </linearGradient>
  </defs>
</svg>

@let r = selectedResult();

<ng-template #resultDialog>
  @if (r) {
      <div class="dialog__header" mat-dialog-title>
        <div class="dialog__title-group">
        <div class="dialog__icon-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="url(#dlgDropGrad2)">
            <defs>
              <linearGradient id="dlgDropGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#38bdf8"/>
                <stop offset="100%" stop-color="#0369a1"/>
              </linearGradient>
            </defs>
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
          </svg>
        </div>
        <div>
          <div class="dialog__well-name">{{ r.wellName }}</div>
          <div class="dialog__subtitle">{{ r.testType | titlecase }} Test · {{ r.aquifer }} Aquifer</div>
        </div>
        </div>
        <button type="button" class="dialog__close" (click)="closeDialog()" aria-label="Close test result dialog">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

    <mat-dialog-content class="dialog__body">
      <div class="metric-grid">

        <div class="metric metric--highlight">
          <div class="metric__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 18s2-2 4-2 4 2 4 2 4-2 4 2"/>
              <path d="M4 22s2-2 4-2 4 2 4 2 4-2 4 2"/>
              <line x1="18" y1="4" x2="18" y2="14"/>
              <polyline points="15 7 18 4 21 7"/>
            </svg>
          </div>
          <div class="metric__value">{{ r.flowRate | number }}</div>
          <div class="metric__label">Flow Rate (GPM)</div>
        </div>

        @if (r.testType === 'PUMP') {
          <div class="metric metric--highlight">
            <div class="metric__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="metric__value">{{ r.rpm | number }}</div>
            <div class="metric__label">RPM</div>
          </div>
        } @else {
          <div class="metric metric--highlight">
            <div class="metric__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <line x1="12" y1="2" x2="12" y2="22"/>
                <path d="M5 10c2-2 5-3 7 0s5 2 7 0"/>
                <path d="M5 14c2-2 5-3 7 0s5 2 7 0"/>
              </svg>
            </div>
            <div class="metric__value">{{ r.siwhp | number }}</div>
            <div class="metric__label">SIWHP (FT)</div>
          </div>
        }

        <div class="metric">
          <div class="metric__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <div class="metric__value">{{ r.tds | number }}</div>
          <div class="metric__label">TDS (PPM)</div>
        </div>

        <div class="metric">
          <div class="metric__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
            </svg>
          </div>
          <div class="metric__value">{{ r.temperature | number:'1.0-1' }}°C</div>
          <div class="metric__label">Temperature</div>
        </div>

        <div class="metric">
          <div class="metric__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div class="metric__value">{{ r.productivity | number:'1.2-2' }}</div>
          <div class="metric__label">Productivity (GPM/FT)</div>
        </div>

        <div class="metric" [class.metric--warn]="r.h2s > 0">
          <div class="metric__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
              <line x1="12" y1="9"  x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <div class="metric__value">{{ r.h2s | number }}</div>
          <div class="metric__label">H₂S (PPM)</div>
        </div>

      </div>

      <!-- Summary tags row -->
      <div class="dialog__summary-row">
        <span class="summary-tag summary-tag--aquifer">{{ r.aquifer }}</span>
        <span class="summary-tag">{{ (r.testType | titlecase) + ' Test' }}</span>
        @if (r.h2s > 0) {
          <span class="summary-tag summary-tag--warn">H₂S Detected</span>
        }
      </div>
    </mat-dialog-content>
  }
</ng-template>
