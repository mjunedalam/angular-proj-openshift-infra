protected readonly currentUserEmail = computed(() => this.authStore.userEmail());
protected readonly canSendEmail = computed(() =>
  !!this.currentUserEmail() && this.reportCount() > 0 && !this.isSending(),
);

protected async sendEmailToMe(): Promise<void> {
  if (!this.canSendEmail()) {
    this.errorMessage.set('No logged-in email or report data is available.');
    this.sendSuccess.set(false);
    return;
  }

  this.isSending.set(true);
  this.sendSuccess.set(false);
  this.errorMessage.set('');

  try {
    const emailRequest = this.emailService.buildEmailRequest(
      this.reports(),
      'data:image/png;base64,MOCK_REPORT_MAP_IMAGE',
      [],
    );

    await firstValueFrom(this.emailService.sendEmail(emailRequest));
    this.sendSuccess.set(true);
  } catch (error) {
    this.errorMessage.set(
      error instanceof Error ? error.message : 'Failed to send email.',
    );
  } finally {
    this.isSending.set(false);
  }
}
3. Service Builds Request
