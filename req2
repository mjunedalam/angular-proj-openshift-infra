private getCurrentUserEmail(): string {
  const userEmail = this.authStore.userEmail();

  if (!userEmail) {
    throw new Error('No logged-in user email is available.');
  }

  return userEmail;
}

buildEmailRequest(
  reports: MorningReport[],
  mapImageData: string,
  waterWellTestResults?: WaterWellTestResult[],
): EmailRequest {
  const userEmail = this.getCurrentUserEmail();

  return {
    userEmail,
    subject: EMAIL_SUBJECT,
    from: EMAIL_FROM,
    to: [userEmail],
    cc: EMAIL_CC,
    replyTo: userEmail,
    templateName: EMAIL_TEMPLATE_NAME,
    generatePdf: false,
    templateData: {
      morningReport: reports,
      mapImageData,
      waterWellTestResults
    }
  };
}
4. Service Sends API Call
email.service.ts (line 30)

sendEmail(emailRequest: EmailRequest): Observable<void> {
  const headers = new HttpHeaders({ 'Content-Type': 'application/json' });
  const userEmail = emailRequest.userEmail?.trim() || this.getCurrentUserEmail();

  return this.http.post<void>(this.apiUrl, {
    ...emailRequest,
    userEmail,
    to: [userEmail],
  }, { headers });
}
