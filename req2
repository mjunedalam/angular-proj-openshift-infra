  // ── Logo ──────────────────────────────────────────────────────────────────
  &__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
  }

  &__logo-icon {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.65));
  }

  &__logo-text {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 19px;
    font-weight: 800;
    letter-spacing: 2.5px;
    color: #38bdf8;
    text-shadow: 0 0 18px rgba(56, 189, 248, 0.5);
    text-transform: uppercase;
  }

  // ── Center title ──────────────────────────────────────────────────────────
  &__title {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 24px;

    h1 {
      margin: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: $nav-text;
      white-space: nowrap;
    }
  }

  // ── Right: user area ──────────────────────────────────────────────────────
  &__user {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
    margin-left: auto;
  }

  &__notifications {
    position: relative;
  }

  &__icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid $nav-border;
    border-radius: 10px;
    cursor: pointer;
    color: $nav-muted;
    transition: background 0.2s $ease, border-color 0.2s $ease, color 0.2s $ease, box-shadow 0.2s $ease;
    position: relative;

    svg { width: 18px; height: 18px; }

    &:hover {
      background: $nav-hover-bg;
      border-color: rgba(56, 189, 248, 0.4);
      color: #38bdf8;
      box-shadow: 0 0 12px rgba(56, 189, 248, 0.2);
    }
  }

  &__divider {
    width: 1px;
    height: 26px;
    background: $nav-border;
  }

  // ── User info (name text) ─────────────────────────────────────────────────
  &__user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  &__user-name {
    font-size: 13.5px;
    font-weight: 700;
    color: $nav-text;
    letter-spacing: 0.2px;
    line-height: 1.2;
  }

  &__last-login {
    font-size: 10px;
    color: $nav-muted;
    letter-spacing: 0.15px;
    line-height: 1.2;
