// ── Layout constants ─────────────────────────────────────────────────────────
$nav-h:        62px;
$ease:         cubic-bezier(0.4, 0, 0.2, 1);
// Light-on-dark palette for the dark navy bar
$nav-text:     rgba(255, 255, 255, 0.92);
$nav-muted:    rgba(255, 255, 255, 0.55);
$nav-border:   rgba(255, 255, 255, 0.10);
$nav-hover-bg: rgba(14, 165, 233, 0.14);

// ── Host ─────────────────────────────────────────────────────────────────────
:host {
  display: block;
  flex-shrink: 0;
}

// ── Shell ────────────────────────────────────────────────────────────────────
.top-navbar {
  display: flex;
  align-items: center;
  height: $nav-h;
  padding: 0 20px 0 0;
  background: var(--bg-topbar);
  border-bottom: 1px solid $nav-border;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  position: relative;
  z-index: 100;

  // Subtle grid texture
  &::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(56, 189, 248, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.035) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  // Bottom accent line
  &::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(14, 165, 233, 0.55) 30%,
      rgba(14, 165, 233, 0.55) 70%,
      transparent
    );
    pointer-events: none;
  }

  // ── Brand ─────────────────────────────────────────────────────────────────
  &__brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 10px;
    padding: 0 14px;
    height: 100%;
    border-right: 1px solid $nav-border;
    min-width: 224px;
    transition: min-width 0.26s $ease;
  }

  // ── Hamburger ─────────────────────────────────────────────────────────────
  &__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
