      border-radius: 2px;
      transition: background 0.2s, transform 0.25s;

      &:nth-child(1) { width: 20px; }
      &:nth-child(2) { width: 14px; }
      &:nth-child(3) { width: 17px; }
    }

    &:hover {
      background: $nav-hover-bg;
      span { background: #38bdf8; }
    }

