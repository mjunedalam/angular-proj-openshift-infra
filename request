.date-picker-input {
  appearance: none;
  -webkit-appearance: none;
  border: 1.5px solid $chip-border;
  border-radius: 6px;
  padding: 4px 8px;
  font-size: 12px;
  font-family: inherit;
  color: $chip-text;
  background: $chip-bg;
  cursor: pointer;

  &:focus-visible {
    outline: 3px solid rgba($accent, 0.4);
    outline-offset: 2px;
  }

  &:hover {
    background: #f8fafc;
    border-color: $accent;
  }
}
