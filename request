// ── Layout constants ─────────────────────────────────────────────────────────
$nav-h:        62px;
$ease:         cubic-bezier(0.4, 0, 0.2, 1);
// Light-on-dark palette for the dark navy bar
$nav-text:     rgba(255, 255, 255, 0.92);
$nav-muted:    rgba(255, 255, 255, 0.55);
$nav-border:   rgba(255, 255, 255, 0.10);
$nav-hover-bg: rgba(14, 165, 233, 0.14);

// ── Host ─────────────────────────────────────────────────────────────────────
:host {
  display: block;
  flex-shrink: 0;
}

// ── Shell ────────────────────────────────────────────────────────────────────
.top-navbar {
  display: flex;
  align-items: center;
  height: $nav-h;
  padding: 0 20px 0 0;
  background: var(--bg-topbar);
  border-bottom: 1px solid $nav-border;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  position: relative;
  z-index: 100;

  // Subtle grid texture
  &::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(56, 189, 248, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.035) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  // Bottom accent line
  &::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(14, 165, 233, 0.55) 30%,
      rgba(14, 165, 233, 0.55) 70%,
      transparent
    );
    pointer-events: none;
  }

  // ── Brand ─────────────────────────────────────────────────────────────────
  &__brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 10px;
    padding: 0 14px;
    height: 100%;
    border-right: 1px solid $nav-border;
    min-width: 224px;
    transition: min-width 0.26s $ease;
  }

  // ── Hamburger ─────────────────────────────────────────────────────────────
  &__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 8px;
    flex-shrink: 0;
    transition: background 0.15s;

    span {
      display: block;
      height: 2px;
      background: $nav-muted;
      border-radius: 2px;
      transition: background 0.2s, transform 0.25s;

      &:nth-child(1) { width: 20px; }
      &:nth-child(2) { width: 14px; }
      &:nth-child(3) { width: 17px; }
    }

    &:hover {
      background: $nav-hover-bg;
      span { background: #38bdf8; }
    }

    &--active span { background: #38bdf8; }
  }

  // ── Logo ──────────────────────────────────────────────────────────────────
  &__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
  }

  &__logo-icon {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.65));
  }

  &__logo-text {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 19px;
    font-weight: 800;
    letter-spacing: 2.5px;
    color: #38bdf8;
    text-shadow: 0 0 18px rgba(56, 189, 248, 0.5);
    text-transform: uppercase;
  }

  // ── Center title ──────────────────────────────────────────────────────────
  &__title {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 24px;

    h1 {
      margin: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: $nav-text;
      white-space: nowrap;
    }
  }

  // ── Right: user area ──────────────────────────────────────────────────────
  &__user {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
    margin-left: auto;
  }

  &__notifications {
    position: relative;
  }

  &__icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid $nav-border;
    border-radius: 10px;
    cursor: pointer;
    color: $nav-muted;
    transition: background 0.2s $ease, border-color 0.2s $ease, color 0.2s $ease, box-shadow 0.2s $ease;
    position: relative;

    svg { width: 18px; height: 18px; }

    &:hover {
      background: $nav-hover-bg;
      border-color: rgba(56, 189, 248, 0.4);
      color: #38bdf8;
      box-shadow: 0 0 12px rgba(56, 189, 248, 0.2);
    }
  }

  &__divider {
    width: 1px;
    height: 26px;
    background: $nav-border;
  }

  // ── User info (name text) ─────────────────────────────────────────────────
  &__user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  &__user-name {
    font-size: 13.5px;
    font-weight: 700;
    color: $nav-text;
    letter-spacing: 0.2px;
    line-height: 1.2;
  }

  &__roles {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    justify-content: flex-end;
    margin-top: 3px;
  }

  &__role-chip {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #38bdf8;
    background: rgba(56, 189, 248, 0.10);
    border: 1px solid rgba(56, 189, 248, 0.28);
    border-radius: 4px;
    padding: 1px 6px;
    line-height: 1.6;
    white-space: nowrap;
  }

  // ── Menu ─────────────────────────────────────────────────────────────────
  &__menu {
    position: relative;
  }

  &__menu-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 8px 4px 14px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid $nav-border;
    border-radius: 999px;
    color: $nav-text;
    cursor: pointer;
    transition: background 0.2s $ease, border-color 0.2s $ease, box-shadow 0.2s $ease;

    &:hover {
      background: $nav-hover-bg;
      border-color: rgba(56, 189, 248, 0.4);
      box-shadow: 0 0 14px rgba(56, 189, 248, 0.16);
    }

    &:focus-visible {
      outline: 2px solid #38bdf8;
      outline-offset: 2px;
    }
  }

  &__avatar {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #0ea5e9 0%, #0369a1 100%);
    border: 2px solid rgba(56, 189, 248, 0.55);
    border-radius: 50%;
    font-size: 13px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.5px;
    box-shadow: 0 0 12px rgba(14, 165, 233, 0.45);
  }

  &__chevron {
    width: 15px;
    height: 15px;
    color: $nav-muted;
    flex-shrink: 0;
    transition: transform 0.25s $ease;
  }
}

