    color: #475569;
    letter-spacing: 0.01em;
    transition: color 0.18s;
    flex: 1;
    text-align: left;
  }

  // Lock badge
  &__lock {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: rgba(220, 38, 38, 0.10);
    color: #ef4444;
    border: 1px solid rgba(220, 38, 38, 0.25);
    flex-shrink: 0;
    transition: background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;

    svg {
      width: 13px;
      height: 13px;
      stroke: currentColor;
    }
  }

  // Locked state
  &--locked {
    opacity: 0.72;

    &:hover {
      opacity: 1;

      .ql-item__lock {
        background: rgba(220, 38, 38, 0.20);
        color: #dc2626;
        box-shadow:
          0 0 0 1px rgba(220, 38, 38, 0.35),
          0 0 10px rgba(220, 38, 38, 0.25);
      }
    }
  }
}

// ══════════════════ MAP WIDGET ════════════════════════════════════════════════
.map-widget {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  backdrop-filter: blur(6px);
  display: flex;
  flex-direction: column;
  align-items: center;

  // Globe sits half above the map frame
  &__globe {
    width: 72px;
    height: 72px;
    margin-top: 14px;
    margin-bottom: -10px;
    z-index: 2;
    filter: drop-shadow(0 6px 18px rgba(6, 182, 212, 0.55));
    animation: globe-float 4s ease-in-out infinite;

    svg { width: 100%; height: 100%; }
  }

  // Inner frame: depth bar + map
  &__frame {
    display: flex;
    width: 100%;
    gap: 0;
  }

  // Left blue depth bar
  &__depth-bar {
    width: 14px;
    flex-shrink: 0;
    background: linear-gradient(180deg, #1d4ed8 0%, #0ea5e9 50%, #06b6d4 100%);
    min-height: 140px;
  }

  // Map area
  &__map {
    flex: 1;
    display: flex;
    position: relative;
    background: #dbeafe;
    min-height: 140px;
  }

  // Right legend bar
  &__legend {
    width: 20px;
    flex-shrink: 0;
    background: linear-gradient(180deg, #0f766e 0%, #0d9488 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-evenly;
    padding: 8px 0;
  }
}

// SVG map fills the space
.map-svg {
  flex: 1;
  width: 100%;
  height: 100%;
  display: block;
}

// Legend dots
.legend-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.5);

  &--green  { background: #22c55e; }
  &--red    { background: #ef4444; }
  &--blue   { background: #3b82f6; }
  &--yellow { background: #f59e0b; }
  &--grey   { background: #94a3b8; }
}

// Globe floating animation
@keyframes globe-float {
  0%, 100% { transform: translateY(0);   }
  50%       { transform: translateY(-5px); }
}
