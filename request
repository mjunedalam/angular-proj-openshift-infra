<div class="home">

  <!-- ══ Quick List ══ -->
  <div class="quick-list">
    <div class="quick-list__title">Quick List</div>

    @for (item of quickItems; track item.route) {
      <button
        class="ql-item"
        [class.ql-item--locked]="isLocked(item)"
        (click)="navigate(item.route)"
      >
        <span class="ql-item__icon" [style.background]="'radial-gradient(circle at 35% 35%, ' + item.color + 'cc, ' + item.color + '55)'">
          <svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"
               stroke-linecap="round" stroke-linejoin="round">
            @for (p of item.iconPaths; track $index) {
              <path [attr.d]="p" />
            }
          </svg>
        </span>

        <span class="ql-item__label">{{ item.label }}</span>

        @if (isLocked(item)) {
          <span
            class="ql-item__lock"
            matTooltip="Access restricted — contact your administrator to request access to this module."
            matTooltipPosition="after"
            matTooltipClass="sidenav-lock-tooltip"
            [matTooltipShowDelay]="180"
            aria-label="Access restricted"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
          </span>
        }
      </button>
    }
  </div>

</div>
