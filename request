    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  &:hover {
    background: rgba(220, 38, 38, 0.07);
    border-color: rgba(220, 38, 38, 0.3);
  }
}

// ── Mat-badge override ────────────────────────────────────────────────────────
:host ::ng-deep .mat-badge-content {
  font-size: 9px;
  font-weight: 800;
  min-width: 17px;
  height: 17px;
  line-height: 17px;
  border-radius: 6px;
  letter-spacing: 0.3px;
}

// ── Responsive ───────────────────────────────────────────────────────────────
@media (max-width: 900px) {
  .top-navbar {
    &__title      { display: none; }
    &__user       { gap: 10px; }
    &__user-info  { display: none; }
    &__menu-trigger { padding-left: 6px; }
  }
}
