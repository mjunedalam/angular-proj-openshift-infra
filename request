import { Component, computed, inject, OnInit, signal, ViewChild } from '@angular/core';
import { MatSnackBar } from '@angular/material/snack-bar';
import { EmailService } from '../../core/services/email/email.service';
import { EmailStore } from '../../core/stores/email/email.store';
import { MorningReport } from '../../models/morining-report.model';
import { MoriningReportService } from '../../services/morining-report.service';
import { SHARED_MODULES } from '../../shared/shared.module';
import { WwellmapComponent } from '../../wwellmap/wwellmap.component';
import { FormControl, FormsModule, ReactiveFormsModule } from '@angular/forms';
import { ApiResponse } from '../../core/models/api-response.model';
import { WaterWellTestResult } from '../../models/water-well-test-result';
import { catchError, finalize, of, tap } from 'rxjs';

@Component({
  selector: 'app-morningreport',
  imports: [...SHARED_MODULES, WwellmapComponent, ReactiveFormsModule, FormsModule],
  providers: [MoriningReportService],
  templateUrl: './morningreport.component.html',
  styleUrl: './morningreport.component.scss'
})
export class MorningreportComponent implements OnInit {

  morningReports!: MorningReport[];
  @ViewChild('wwellMap') wwellMap!: WwellmapComponent;

  private emailStore = inject(EmailStore);
  private morningService = inject(MoriningReportService);
  private snackBar = inject(MatSnackBar);
  private emailService = inject(EmailService)

  morningReport = signal<MorningReport[]>([]);
  private readonly _wellTestResults = signal<ApiResponse<WaterWellTestResult>>({
    statusCode: 0,
    error: false,
    message: "",
    data: []
  });

  loading = signal(true);
  today = signal(new Date())
  rigStatuses = signal<string[]>([]);

  public readonly hasError = computed(() => this._wellTestResults().error);
  public readonly errorMessage = computed(() => this._wellTestResults().message);
  public readonly waterWelltestResult = computed(() => this._wellTestResults().data);
  public readonly statusCode = computed(() => this._wellTestResults().statusCode);
  public readonly isLoading = signal<boolean>(false);

  rigStatusCtrl = new FormControl('');


  supportingInfo = ["ANDR GOSP-1", "DMDA-2"];



  ngOnInit(): void {
    this.loadMorningReportData();
    this.loadWaterWellTestResults();
  }

  private loadWaterWellTestResults(): void {
    this.loading.set(true);

    this.morningService
      .getWaterWellTestResultData()
      .pipe(
        tap((apiResp) => this._wellTestResults.set(apiResp)),
        catchError((err) => {
          const fallback: ApiResponse<WaterWellTestResult> = {
            statusCode: err.status,
            error: true,
            message: err.message,
            data: [],
          };
          this._wellTestResults.set(fallback);
          return of(fallback);
        }),
        finalize(() => this.isLoading.set(false))
      )
      .subscribe();
  }


  loadMorningReportData() {

    this.loading.set(true);
    this.morningService.getMorningReport().subscribe({

      next: reports => {
        this.loading.set(false);
        this.morningReport.set(reports);
      },

      error: (error) => {
        this.loading.set(false);
        this.showError("Failed to load Morning Report");
      }
    })
  }

  onStatusChange(event: Event, index: number) {
    const inputElement = event.target as HTMLInputElement;
    const newRigStatus = inputElement.value;

    this.rigStatuses.update((arr) => {
      const newRigStatuses = [...arr];
      newRigStatuses[index] = newRigStatus;
      return newRigStatuses;
    });


    this.morningReport.update((reports) => {
      const copy = [...reports];
      copy[index] = { ...copy[index], rigStatus: newRigStatus };
      return copy;
    });
  }

  onActionChange(event: Event) {
    const select = event.target as HTMLSelectElement;
    const action = select.value;

    if (action === 'email') {
      this.sendEmail();
    } else if (action === 'download') {
      this.downloadReport();
    }
  }

  async sendEmail() {
    try {
      const morningReport = this.morningReport();
      const mapData = await this.wwellMap.captureMapAsBase64();
      const waterWelltestResults = this.waterWelltestResult();
      const emailRequest = this.emailService.buildEmailRequest(morningReport, mapData!, waterWelltestResults);
      this.emailStore.sendEmail(emailRequest);

      this.snackBar.open('Email sent successfully!', 'Dismiss', {
        duration: 3000,
        panelClass: ['bg-green-500', 'text-white']
      });

    } catch (error) {
      this.showError('Failed to send email. Please try again.');
    }
  }

  downloadReport() {
    this.wwellMap.saveMapImage();
  }

  private showError(message: string) {
    this.snackBar.open(message, 'Dissmiss', {
      duration: 3000,
      panelClass: ['bg-red-500', 'text-white']
    });
  }

}


