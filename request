#datasource
quarkus.datasource.db-kind=oracle
quarkus.datasource.jdbc.driver=oracle.jdbc.driver.OracleDriver
quarkus.native.add-all-charsets=true
quarkus.datasource.jdbc.url=${JDBC_URL}
quarkus.datasource.username=${AGWA_USERNAME}
quarkus.datasource.password=${AGWA_PASSWORD}

quarkus.http.test-port=9696

#mybatis
quarkus.mybatis.mapper-locations=mappers/
quarkus.mybatis.jdbc-type-for-null=varchar
quarkus.mybatis.use-actual-param-name=true

#CSRF
quarkus.rest-csrf.cookie-name=XSRF-TOKEN
quarkus.rest-csrf.token-header-name=X-XSRF-TOKEN
quarkus.rest-csrf.cookie-http-only=false
quarkus.rest-csrf.enabled=false


%dev.quarkus.rest-csrf.enabled=false
%test.rest-quarkus.csrf.enabled=false

#opentelemetry
quarkus.otel.exporter.otlp.endpoint=http://otel-collector.tempo-monolithic.svc.cluster.local:4317/

quarkus.rest-client.logging.scope=request-response
quarkus.rest-client.logging.body-limit=5000

quarkus.http.cors=true
#quarkus.http.cors.origins=http://localhost:4200,https://agwa-frontend-dev.apps.ocpb.enp.aramco.com.sa,
quarkus.http.cors.methods=GET,POST,PUT,DELETE,OPTIONS
quarkus.http.cors.headers=Content-Type,Authorization

quarkus.http.cors.origins=*
quarkus.swagger-ui.always-include=true

#dailyreports
agwa.dailyreports.path=/well-presentation-docs
#5MB max
agwa.max.filesize=5242880

#opentelemetry

quarkus.datasource.jdbc.telemetry=true
quarkus.otel.security-events.enabled=true

quarkus.mybatis.datasource.jdbc.max-size=10
quarkus.mybatis.datasource.jdbc.min-size=5
quarkus.mybatis.datasource.jdbc.initial-size=5
quarkus.datasource.jdbc.acquisition-timeout=100



quarkus.datasource.jdbc.validation-query-sql=SELECT 1 FROM DUAL
quarkus.datasource.jdbc.leak-detection-interval=30S

quarkus.mybatis.transaction-factory=MANAGED

quarkus.datasource.*.jdbc.acquisition-timeout=5S


