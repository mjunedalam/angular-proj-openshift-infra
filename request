// ── Layout constants ────────────────────────────────────────────────────────
$expanded-w:  244px;
$collapsed-w: 64px;
$ease:        cubic-bezier(0.4, 0, 0.2, 1);
$transition:  0.26s $ease;

// Light-on-dark palette — sidenav is a dark navy surface
$nav-text:    rgba(255, 255, 255, 0.88);
$nav-muted:   rgba(255, 255, 255, 0.48);
$nav-border:  rgba(255, 255, 255, 0.08);
$nav-hover-bg: rgba(14, 165, 233, 0.10);

// ── Host ────────────────────────────────────────────────────────────────────
:host {
  display: block;
  flex-shrink: 0;
}

// ── Shell ───────────────────────────────────────────────────────────────────
.sidenav {
  display: flex;
  flex-direction: column;
  width: $expanded-w;
  height: 100%;
  background: var(--bg-sidenav);
  border-right: 1px solid $nav-border;
  overflow: hidden;
  transition: width $transition;
  position: relative;

  // Subtle right-edge glow
  &::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 1px; height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(14, 165, 233, 0.35),
      rgba(14, 165, 233, 0.08) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  // ── Collapsed state ────────────────────────────────────────────────────
  &--collapsed {
    width: $collapsed-w;

    .sidenav__label,
    .sidenav__footer-text {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .sidenav__btn {
      justify-content: center;
      padding: 0;
    }

    .sidenav__icon { margin-right: 0; }

    .sidenav__section-label { opacity: 0; height: 0; padding: 0; overflow: hidden; }
  }

  // ── Section label ──────────────────────────────────────────────────────
  &__section-label {
    padding: 20px 18px 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: $nav-muted;
    transition: opacity $transition, height $transition, padding $transition;
    white-space: nowrap;
    flex-shrink: 0;
    overflow: hidden;
  }

  // ── List ───────────────────────────────────────────────────────────────
  &__list {
    list-style: none;
    margin: 0;
    padding: 14px 0 18px;
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;

    &::-webkit-scrollbar { width: 0; }
  }

  &__item {
    padding: 4px 12px;
  }

  // ── Nav button ─────────────────────────────────────────────────────────
  &__btn {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: 58px;
    padding: 0 16px 0 10px;
    border: none;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    color: $nav-muted;
    cursor: pointer;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.2px;
    gap: 2px;
    transition:
      background $transition,
      color $transition,
      box-shadow $transition,
      transform 0.15s ease;
    overflow: hidden;
    white-space: nowrap;

    &:hover {
      background: rgba(14, 165, 233, 0.14);
      color: $nav-text;
      transform: translateX(2px);
      box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.14);

      .sidenav__icon {
        background: rgba(14, 165, 233, 0.16);

        svg {
          stroke: #38bdf8;
          filter: drop-shadow(0 0 5px rgba(14, 165, 233, 0.4));
        }
      }
    }

    &--active {
      background: linear-gradient(90deg, rgba(14, 165, 233, 0.2) 0%, rgba(14, 165, 233, 0.08) 100%);
      color: #dff6ff;
      font-weight: 800;
      box-shadow:
        inset 0 0 0 1px rgba(56, 189, 248, 0.28),
        0 8px 18px rgba(2, 132, 199, 0.12);

      .sidenav__icon {
        background: rgba(14, 165, 233, 0.22);

        svg {
          stroke: #38bdf8;
          filter: drop-shadow(0 0 8px rgba(14, 165, 233, 0.55));
        }
      }
    }
  }

  // ── Icon container ─────────────────────────────────────────────────────
  &__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-right: 13px;
    transition: margin $transition, background $transition;

    svg {
      width: 22px;
      height: 22px;
      stroke: currentColor;
      transition: stroke 0.2s ease, filter 0.2s ease;
    }
  }

  // ── Label ──────────────────────────────────────────────────────────────
  &__label {
    flex: 1;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    color: inherit;
    transition: opacity $transition, width $transition;
    white-space: nowrap;
  }

  // ── Lock icon ──────────────────────────────────────────────────────────
  &__lock {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: rgba(220, 38, 38, 0.15);
    color: #f87171;
    border: 1px solid rgba(220, 38, 38, 0.28);
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;

    svg {
      width: 13px;
      height: 13px;
      stroke: currentColor;
      stroke-width: 2.2;
      flex-shrink: 0;
    }
  }

  &__btn--locked {
    opacity: 0.72;

    .sidenav__icon {
      background: rgba(220, 38, 38, 0.12);

      svg { stroke: #f87171; }
    }

    &:hover {
      background: rgba(220, 38, 38, 0.11);
      color: #fca5a5;
      transform: translateX(2px);
      box-shadow: inset 0 0 0 1px rgba(220, 38, 38, 0.18);
      opacity: 1;

      .sidenav__icon {
        background: rgba(220, 38, 38, 0.22);

        svg {
          stroke: #fca5a5;
          filter: drop-shadow(0 0 5px rgba(220, 38, 38, 0.45));
        }
      }

      .sidenav__lock {
        background: rgba(220, 38, 38, 0.26);
        color: #fca5a5;
        box-shadow:
          0 0 0 1px rgba(220, 38, 38, 0.4),
          0 0 10px rgba(220, 38, 38, 0.35);
      }
    }
  }

  // ── Active indicator (left edge) ────────────────────────────────────────
  &__active-bar {
    position: absolute;
    left: 0;
    top: 9px;
    bottom: 9px;
    width: 4px;
    background: #38bdf8;
    border-radius: 0 4px 4px 0;
    box-shadow: 2px 0 14px rgba(14, 165, 233, 0.55);
  }

  // ── Footer ─────────────────────────────────────────────────────────────
  &__footer {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    border-top: 1px solid $nav-border;
    flex-shrink: 0;
    background: rgba(14, 165, 233, 0.03);
  }

  &__water-logo {
    width: 28px;
    height: 34px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.6));

    svg { width: 100%; height: 100%; }
  }

  &__footer-text {
    font-size: 12.5px;
    font-weight: 800;
    color: $nav-muted;
    letter-spacing: 1.2px;
    white-space: nowrap;
    transition: opacity $transition, width $transition;
    text-transform: uppercase;
  }
}
