  &--red    { background: #ef4444; }
  &--blue   { background: #3b82f6; }
  &--yellow { background: #f59e0b; }
  &--grey   { background: #94a3b8; }
}

// Globe floating animation
@keyframes globe-float {
  0%, 100% { transform: translateY(0);   }
