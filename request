// ── Host ────────────────────────────────────────────────────────────────────
:host {
  display: block;
  flex-shrink: 0;
}

// ── Shell ───────────────────────────────────────────────────────────────────
.sidenav {
  display: flex;
  flex-direction: column;
  width: $expanded-w;
  height: 100%;
  background: var(--bg-sidenav);
  border-right: 1px solid $nav-border;
  overflow: hidden;
  transition: width $transition;
  position: relative;

  // Subtle right-edge glow
  &::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 1px; height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(14, 165, 233, 0.35),
      rgba(14, 165, 233, 0.08) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  // ── Collapsed state ────────────────────────────────────────────────────
  &--collapsed {
    width: $collapsed-w;

    .sidenav__label,
    .sidenav__footer-text {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .sidenav__btn {
      justify-content: center;
      padding: 0;
    }

    .sidenav__icon { margin-right: 0; }

    .sidenav__section-label { opacity: 0; height: 0; padding: 0; overflow: hidden; }
