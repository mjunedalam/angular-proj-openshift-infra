    if (!data) return false;
    return data.flowType === 'Y' || data.testType.toLowerCase() === 'flow';
  });

  protected readonly canUpdate = computed(() =>
    this.rbac.canUpdateRoute('active-wwell', this.auth.user()?.groups ?? []),
  );
