import io.agroal.api.AgroalDataSource;
import jakarta.inject.Inject;
import jakarta.ws.rs.GET;
import jakarta.ws.rs.Path;
import java.util.Map;

@Path("/debug/db-pool")
public class DbPoolResource {

    @Inject
    AgroalDataSource dataSource;

    @GET
    public Map<String, Object> pool() {
        var m = dataSource.getMetrics();
        return Map.of(
            "active", m.activeCount(),
            "available", m.availableCount(),
            "awaiting", m.awaitingCount(),
            "maxUsed", m.maxUsedCount(),
            "acquireCount", m.acquireCount(),
            "creationCount", m.creationCount(),
            "blockingTimeAvgMs", m.blockingTimeAverage().toMillis(),
            "creationTimeAvgMs", m.creationTimeAverage().toMillis()
        );
    }
}
